<view class="page chat-detail-page">
  <!-- Header -->
  <view class="page-header-bar detail-header">
    <view class="header-left" bindtap="goBack">
      <view class="back-arrow"></view>
    </view>
    <view class="header-center" bindtap="goToUserHome">
      <image class="detail-header-avatar" src="{{userAvatar}}" mode="aspectFill" lazy-load/>
      <text class="header-title">{{userName}}</text>
    </view>
    <view class="header-action"></view>
  </view>

  <!-- Messages -->
  <scroll-view scroll-y class="messages-wrap" style="padding-bottom: {{bottomPaddingPx}}px;" scroll-into-view="{{scrollIntoView}}" enable-back-to-top>
    <view class="messages-inner">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="msg-row {{item.self ? 'msg-row-self' : 'msg-row-other'}}"
      >
        <image wx:if="{{!item.self}}" class="msg-avatar" src="{{userAvatar}}" mode="aspectFill" lazy-load bindtap="goToUserHome"/>

        <!-- Image message -->
        <view wx:if="{{item.type === 'image'}}" class="msg-bubble msg-bubble-image {{item.self ? 'msg-bubble-self' : 'msg-bubble-other'}}">
          <image class="msg-image" src="{{item.content}}" mode="widthFix" lazy-load bindtap="previewImage" data-src="{{item.content}}"/>
        </view>

        <!-- Text message -->
        <view wx:else class="msg-bubble {{item.self ? 'msg-bubble-self' : 'msg-bubble-other'}}">
          <text class="msg-text">{{item.content}}</text>
        </view>

        <image wx:if="{{item.self}}" class="msg-avatar" src="{{myAvatar}}" mode="aspectFill" lazy-load/>
      </view>
    </view>
  </scroll-view>

  <!-- Input Area -->
  <view class="input-area safe-bottom" style="bottom: {{areaOffset}}px;">
    <!-- Toolbar -->
    <view class="input-toolbar">
      <view class="tool-btn {{showEmojiPanel ? 'tool-btn-active' : ''}}" bindtap="toggleEmojiPanel">
        <text class="tool-icon">😊</text>
      </view>
      <view class="tool-btn" bindtap="chooseImage">
        <text class="tool-icon">🖼️</text>
      </view>
    </view>

    <!-- Input Box -->
    <view class="input-box">
      <input
        class="msg-input"
        placeholder="说点什么..."
        placeholder-class="msg-placeholder"
        value="{{inputValue}}"
        focus="{{focusInput}}"
        adjust-position="{{false}}"
        bindinput="onInput"
        confirm-type="send"
        bindconfirm="sendMessage"
        bindfocus="onInputFocus"
      />
      <view class="send-btn {{inputValue ? 'send-btn-active' : ''}}" bindtap="sendMessage">
        <view class="send-arrow"></view>
      </view>
    </view>

    <!-- Emoji Panel -->
    <view wx:if="{{showEmojiPanel}}" class="emoji-panel">
      <scroll-view scroll-y class="emoji-scroll">
        <view class="emoji-grid">
          <view
            class="emoji-item"
            wx:for="{{emojis}}"
            wx:key="*this"
            bindtap="selectEmoji"
            data-emoji="{{item}}"
          >
            <text class="emoji-char">{{item}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
