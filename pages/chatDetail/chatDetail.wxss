/* ── Page ── */
.chat-detail-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-base);
}

/* ── Header ── */
.detail-header .header-left {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid var(--text-primary);
  border-bottom: 3rpx solid var(--text-primary);
  transform: rotate(45deg);
}

.detail-header .header-center {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-header-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

/* ── Messages ── */
.messages-wrap {
  flex: 1;
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  box-sizing: border-box;
}

.messages-inner {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.msg-row-self {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  word-break: break-word;
}

.msg-bubble-other {
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-subtle);
  border-top-left-radius: 4rpx;
}

.msg-bubble-self {
  background: var(--accent);
  color: #ffffff;
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.5;
}

.msg-bubble-self .msg-text {
  color: #ffffff;
}

/* Image message bubble */
.msg-bubble-image {
  padding: 8rpx;
  overflow: hidden;
}

.msg-image {
  max-width: 100%;
  max-height: 400rpx;
  border-radius: 16rpx;
  display: block;
}

/* ── Input Area ── */
.input-area {
  position: fixed;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-elevated);
  border-top: 1rpx solid var(--border-subtle);
  z-index: 10;
  /* bottom 通过内联样式动态控制 */
}

/* Toolbar */
.input-toolbar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  transition: background 0.15s ease;
}

.tool-btn:active {
  background: var(--border-medium);
}

.tool-btn-active {
  background: var(--accent-soft);
}

.tool-icon {
  font-size: 32rpx;
  line-height: 1;
}

/* Input Box */
.input-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.msg-input {
  flex: 1;
  background: var(--bg-base);
  border: 1rpx solid var(--border-subtle);
  border-radius: 9999rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.msg-placeholder {
  color: var(--text-muted);
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
  flex-shrink: 0;
}

.send-btn-active {
  background: var(--accent);
}

.send-arrow {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 14rpx solid #ffffff;
  margin-left: 4rpx;
}

/* Emoji Panel */
.emoji-panel {
  margin-top: 16rpx;
  height: 500rpx;
  background: var(--bg-base);
  border-radius: 16rpx;
  overflow: hidden;
}

.emoji-scroll {
  height: 100%;
}

.emoji-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 8rpx;
}

.emoji-item {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: var(--bg-surface);
  transition: background 0.1s ease;
}

.emoji-item:active {
  background: var(--border-medium);
}

.emoji-char {
  font-size: 36rpx;
  line-height: 1;
}
