<view class="page">
  <!-- Header -->
  <view class="sub-header">
    <view class="back-btn" bindtap="goBack">
      <view class="back-arrow"></view>
    </view>
    <text class="sub-title">关注</text>
    <view class="spacer"></view>
  </view>

  <scroll-view scroll-y class="content">
    <view class="content-inner">
      <view class="page-header anim-fade-in-up">
        <text class="page-title display-lg">关注</text>
        <text class="page-subtitle body">与宁静的灵魂相连</text>
      </view>

      <view class="following-list">
        <view
          class="following-item anim-fade-in-up"
          style="animation-delay: {{(index + 1) * 0.06}}s"
          wx:for="{{following}}"
          wx:key="id"
        >
          <view class="following-info" bindtap="goToUserHome" data-name="{{item.name}}">
            <view wx:if="{{item.isOfficial}}" class="following-avatar official-avatar">
              <text class="official-letter">{{item.name[0]}}</text>
            </view>
            <image wx:else class="following-avatar" src="{{item.avatar}}" mode="aspectFill"/>
            <view class="following-meta">
              <text class="following-name">{{item.name}}</text>
              <text class="following-handle">{{item.handle}}</text>
            </view>
          </view>
          <view class="follow-btn {{item.isFollowing ? '' : 'follow-btn-inactive'}}" bindtap="toggleFollow" data-id="{{item.id}}">{{item.isFollowing ? '已关注' : '关注'}}</view>
        </view>
      </view>

      <view class="list-end">
        <view class="list-end-line"></view>
        <view class="list-end-dot"></view>
        <view class="list-end-line"></view>
      </view>
    </view>
  </scroll-view>
</view>
