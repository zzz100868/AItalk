<view class="page">
  <view class="hero-glow"></view>

  <page-header variant="dark" title="我的" show-dot />

  <scroll-view scroll-y class="content safe-bottom" enable-back-to-top>
    <view class="content-inner">
      <!-- Profile Hero -->
      <view class="profile-hero anim-fade-in-up">
        <view class="avatar-wrapper">
          <view class="avatar-frame anim-scale-in">
            <image class="profile-avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
            <view class="avatar-ring"></view>
            <view class="avatar-ring-outer"></view>
          </view>
        </view>
        <view class="profile-info">
          <text class="profile-name">{{userInfo.nickName}}</text>
          <view class="profile-id-row">
            <text class="profile-id">ID {{userInfo.id}}</text>
            <view class="id-copy" bindtap="copyId"></view>
          </view>
          <text class="profile-bio">{{userInfo.bio}}</text>
        </view>
      </view>

      <!-- Menu Section: 个人中心 -->
      <view class="menu-section anim-fade-in-up" style="animation-delay: 0.18s">
        <view class="section-header">
          <text class="section-label">个人中心</text>
          <view class="section-line"></view>
        </view>
        <view class="menu-card">
          <!-- Photo Gallery -->
          <view class="photo-section">
            <view class="photo-header">
              <text class="photo-title">生活照</text>
              <text class="photo-count">{{photos.length}}/8</text>
            </view>
            <view class="photo-grid">
              <view
                class="photo-item"
                wx:for="{{photos}}"
                wx:key="index"
                bindtap="previewPhoto"
                data-index="{{index}}"
                bindlongpress="deletePhoto"
                data-del-index="{{index}}"
              >
                <image class="photo-img" src="{{item}}" mode="aspectFill"/>
                <view class="photo-delete" catchtap="deletePhoto" data-del-index="{{index}}">
                  <view class="photo-delete-icon"></view>
                </view>
              </view>
              <view wx:if="{{photos.length < 8}}" class="photo-add" bindtap="choosePhoto">
                <view class="photo-add-icon"></view>
                <text class="photo-add-text">添加</text>
              </view>
            </view>
            <text class="photo-hint">长按图片可删除</text>
          </view>
        </view>
      </view>

      <!-- Menu Section: 系统 -->
      <view class="menu-section anim-fade-in-up" style="animation-delay: 0.26s">
        <view class="section-header">
          <text class="section-label">系统</text>
          <view class="section-line"></view>
        </view>
        <view class="menu-card">
          <view class="menu-item" bindtap="goToSettings">
            <view class="menu-item-content">
              <text class="menu-title">设置</text>
              <text class="menu-desc">账号、隐私与通知</text>
            </view>
            <view class="menu-arrow"></view>
          </view>
        </view>
      </view>

      <!-- Version Footer -->
      <view class="version-footer anim-fade-in-up" style="animation-delay: 0.34s">
        <text class="version-text">Stitch AI v1.0</text>
      </view>
    </view>
  </scroll-view>
</view>
