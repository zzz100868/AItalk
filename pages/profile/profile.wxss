.page {
  min-height: 100vh;
  background: #faf9f7;
  position: relative;
  overflow: hidden;
  color: #1c1917;
}

/* ── Ambient Glow ── */
.hero-glow {
  position: absolute;
  top: -100rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 800rpx;
  height: 600rpx;
  pointer-events: none;
  z-index: 0;
}

.hero-glow::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(
    ellipse at center,
    rgba(196, 113, 90, 0.08) 0%,
    rgba(196, 113, 90, 0.03) 40%,
    transparent 70%
  );
  animation: meshFloat1 20s ease-in-out infinite;
}

.hero-glow::after {
  content: '';
  position: absolute;
  top: 20%;
  right: -30%;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.05) 0%, transparent 60%);
  filter: blur(60rpx);
  animation: meshFloat2 24s ease-in-out infinite;
}

/* ── Dark Header ── */
.dark-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
}

.dark-header .header-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #57534e;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.dark-header .notification-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12rpx var(--accent-glow);
}

/* ── Content ── */
.content {
  padding-top: calc(100rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 16rpx 40rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 56rpx;
}

/* ═══════════════════════════════════════
   PROFILE HERO — Oversized Typography
   ═══════════════════════════════════════ */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 32rpx;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 12rpx;
}

.avatar-frame {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  z-index: 1;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  border: 3rpx solid rgba(28, 25, 23, 0.06);
  position: relative;
  z-index: 1;
  box-shadow: 0 24rpx 80rpx rgba(196, 113, 90, 0.12);
}

.avatar-ring {
  position: absolute;
  inset: -10rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(196, 113, 90, 0.15);
  animation: ringPulse 4s ease-in-out infinite;
}

.avatar-ring-outer {
  position: absolute;
  inset: -24rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(196, 113, 90, 0.06);
  animation: ringPulse 4s ease-in-out infinite 2s;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.03); opacity: 0.8; }
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.profile-name {
  font-size: 56rpx;
  font-weight: 300;
  color: #1c1917;
  letter-spacing: 0.06em;
  line-height: 1.2;
}

.profile-id-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.profile-id {
  font-size: 22rpx;
  color: #78716c;
  font-weight: 400;
  letter-spacing: 0.06em;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.id-copy {
  width: 28rpx;
  height: 28rpx;
  position: relative;
  opacity: 0.3;
  transition: opacity 0.2s ease;
}

.id-copy:active { opacity: 0.8; }

.id-copy::before {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 16rpx;
  border: 1.5rpx solid #78716c;
  border-radius: 3rpx;
  top: 2rpx;
  left: 2rpx;
}

.id-copy::after {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 16rpx;
  border: 1.5rpx solid #78716c;
  border-radius: 3rpx;
  top: 6rpx;
  left: 8rpx;
  background: #faf9f7;
}

.profile-bio {
  margin-top: 8rpx;
  max-width: 80%;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.7;
  color: #57534e;
  font-weight: 300;
  letter-spacing: 0.02em;
}

/* ═══════════════════════════════════════
   STATS — Minimal Counters
   ═══════════════════════════════════════ */
.stats-card {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 64rpx;
  padding: 40rpx 0;
  position: relative;
}

.stats-card::before,
.stats-card::after {
  content: '';
  position: absolute;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(28, 25, 23, 0.06), transparent);
}

.stats-card::before { top: 0; }
.stats-card::after { bottom: 0; }

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: transform 0.2s var(--ease-spring);
}

.stat-item:active {
  transform: scale(0.92);
}

.stat-num {
  color: #1c1917;
  font-size: 48rpx;
  font-weight: 200;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.stat-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #78716c;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: linear-gradient(180deg, transparent, rgba(28, 25, 23, 0.06), transparent);
}

/* ═══════════════════════════════════════
   MENU — Minimal List
   ═══════════════════════════════════════ */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 4rpx;
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #78716c;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(28, 25, 23, 0.06), transparent);
}

.menu-card {
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 4rpx;
  transition: all 0.2s var(--ease-spring);
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(28, 25, 23, 0.04);
}

.menu-item:active {
  opacity: 0.6;
  transform: translateX(8rpx);
}

.menu-item-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 400;
  color: #1c1917;
  letter-spacing: 0.02em;
  line-height: 1.3;
}

.menu-desc {
  font-size: 24rpx;
  color: #78716c;
  line-height: 1.4;
}

.menu-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 1.5rpx solid #78716c;
  border-right: 1.5rpx solid #78716c;
  transform: rotate(45deg);
  flex-shrink: 0;
  transition: transform 0.2s var(--ease-spring);
}

.menu-item:active .menu-arrow {
  transform: rotate(45deg) translateX(4rpx);
}

/* ── Version Footer ── */
.version-footer {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}

.version-text {
  font-size: 20rpx;
  color: rgba(28, 25, 23, 0.1);
  letter-spacing: 0.08em;
}
