.page {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
  overflow: hidden;
}

/* ── Hero Glow Background (animated mesh) ── */
.hero-glow {
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 800rpx;
  height: 800rpx;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.hero-glow::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(
    ellipse at center,
    rgba(196, 113, 90, 0.09) 0%,
    rgba(196, 113, 90, 0.03) 35%,
    transparent 70%
  );
  animation: meshFloat1 16s ease-in-out infinite;
}

.hero-glow::after {
  content: '';
  position: absolute;
  top: 10%;
  right: -20%;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.06) 0%, transparent 65%);
  filter: blur(60rpx);
  animation: meshFloat2 20s ease-in-out infinite;
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ── Profile Hero ── */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 24rpx;
  gap: 28rpx;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-frame {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  z-index: 1;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-full);
  object-fit: cover;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  position: relative;
  z-index: 1;
  box-shadow: var(--shadow-lg);
}

.avatar-ring {
  position: absolute;
  inset: -8rpx;
  border-radius: var(--radius-full);
  border: 2rpx solid rgba(196, 113, 90, 0.2);
  animation: ringPulse 3.5s ease-in-out infinite;
}

.avatar-ring-outer {
  position: absolute;
  inset: -20rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid rgba(196, 113, 90, 0.08);
  animation: ringPulse 3.5s ease-in-out infinite;
  animation-delay: 1.75s;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.04); opacity: 1; }
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.profile-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.profile-id-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 2rpx;
}

.profile-id {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  letter-spacing: 0.04em;
  font-family: 'SF Mono', monospace;
}

.id-copy {
  width: 28rpx;
  height: 28rpx;
  position: relative;
  opacity: 0.5;
  transition: opacity var(--duration-fast) ease;
}

.id-copy:active {
  opacity: 1;
}

.id-copy::before {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 16rpx;
  border: 1.5rpx solid var(--text-tertiary);
  border-radius: 3rpx;
  top: 2rpx;
  left: 2rpx;
}

.id-copy::after {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 16rpx;
  border: 1.5rpx solid var(--text-tertiary);
  border-radius: 3rpx;
  top: 6rpx;
  left: 8rpx;
  background: var(--bg-base);
}

.profile-bio {
  margin-top: 8rpx;
  max-width: 80%;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

/* ── Stats ── */
.stats-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 15%;
  right: 15%;
  height: 2rpx;
  background: var(--accent-gradient);
  opacity: 0.2;
  border-radius: var(--radius-full);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.stat-item:active {
  transform: scale(0.92);
  opacity: 0.8;
}

.stat-num {
  color: var(--text-primary);
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  letter-spacing: 0.06em;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(28, 25, 23, 0.08) 50%,
    transparent 100%
  );
}

/* ── Menu Section ── */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 4rpx;
}

.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(28, 25, 23, 0.06) 0%,
    transparent 100%
  );
}

/* ── Menu Card ── */
.menu-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  transition: background-color var(--duration-fast) ease, transform var(--duration-fast) var(--ease-spring);
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 28rpx;
  right: 28rpx;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(28, 25, 23, 0.04) 0%,
    rgba(28, 25, 23, 0.08) 50%,
    rgba(28, 25, 23, 0.04) 100%
  );
}

.menu-item:active {
  background: rgba(28, 25, 23, 0.03);
  transform: scale(0.99);
}

.menu-item-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  line-height: 1.3;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

.menu-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2.5rpx solid var(--text-muted);
  border-right: 2.5rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-right: 4rpx;
  flex-shrink: 0;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.menu-item:active .menu-arrow {
  transform: rotate(45deg) translateX(4rpx);
}

/* ── Version Footer ── */
.version-footer {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}

.version-text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  opacity: 0.6;
}
