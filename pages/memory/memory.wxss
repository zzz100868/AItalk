.page {
  min-height: 100vh;
  background: #faf9f7;
  position: relative;
  overflow: hidden;
  color: #1c1917;
}

/* ═══════════════════════════════════════
   Ambient Background
   ═══════════════════════════════════════ */
.ambient-glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
  z-index: 0;
  will-change: transform;
}

.ambient-glow-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.1) 0%, transparent 60%);
  top: -180rpx;
  right: -180rpx;
  animation: meshFloat1 18s ease-in-out infinite;
}

.ambient-glow-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(127, 176, 105, 0.05) 0%, transparent 60%);
  bottom: 200rpx;
  left: -200rpx;
  animation: meshFloat2 22s ease-in-out infinite;
}

.ambient-gradient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, rgba(196, 113, 90, 0.04) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ═══════════════════════════════════════
   Dark Header
   ═══════════════════════════════════════ */
.dark-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
}

.dark-header .header-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 2rpx solid rgba(28, 25, 23, 0.08);
}

.dark-header .header-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #57534e;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.dark-header .notification-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12rpx var(--accent-glow);
}

/* ═══════════════════════════════════════
   Content Layer
   ═══════════════════════════════════════ */
.content {
  padding-top: calc(100rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 24rpx 40rpx calc(140rpx + env(safe-area-inset-bottom));
}

.content-chat .content-inner {
  padding-bottom: calc(24rpx + 120rpx + env(safe-area-inset-bottom));
}

/* ═══════════════════════════════════════
   Tab Switcher — Minimal Underline
   ═══════════════════════════════════════ */
.tab-switcher {
  position: relative;
  display: flex;
  margin-bottom: 40rpx;
}

.tab-switcher::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: rgba(28, 25, 23, 0.06);
}

.tab-slider {
  position: absolute;
  bottom: 0;
  left: 0;
  width: calc(100% / 3);
  height: 2rpx;
  background: var(--accent);
  border-radius: 2rpx;
  transition: transform 0.45s var(--ease-spring);
  z-index: 1;
  box-shadow: 0 0 12rpx var(--accent-glow);
}

.tab-pill {
  position: relative;
  z-index: 1;
  flex: 1;
  text-align: center;
  padding-bottom: 20rpx;
  font-size: 28rpx;
  color: #78716c;
  font-weight: 400;
  transition: color 0.3s ease;
  letter-spacing: 0.04em;
}

.tab-pill:active {
  opacity: 0.7;
}

.tab-pill-active {
  color: #1c1917;
  font-weight: 500;
}

/* ═══════════════════════════════════════
   CHAT VIEW
   ═══════════════════════════════════════ */
.chat-view {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 60vh;
}

/* Chat Status Bar */
.chat-status-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.status-num {
  font-size: 36rpx;
  font-weight: 300;
  color: #1c1917;
}

.status-label {
  font-size: 20rpx;
  color: #78716c;
  letter-spacing: 0.08em;
}

.status-divider {
  width: 1rpx;
  height: 36rpx;
  background: rgba(28, 25, 23, 0.06);
}

/* Messages */
.messages {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  flex: 1;
  justify-content: flex-end;
  padding-bottom: 24rpx;
}

.msg-row {
  display: flex;
  width: 100%;
  opacity: 0;
}

.msg-user {
  justify-content: flex-end;
  animation: msgSlideInRight 0.5s var(--ease-out-expo) both;
}

.msg-ai {
  justify-content: flex-start;
  gap: 14rpx;
  animation: msgSlideInLeft 0.5s var(--ease-out-expo) both;
}

.ai-avatar-small {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  margin-top: 8rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
}

.msg-bubble {
  max-width: 78%;
  padding: 24rpx 28rpx;
}

.msg-bubble-user {
  background: rgba(196, 113, 90, 0.12);
  color: #1c1917;
  border-radius: 24rpx 24rpx 6rpx 24rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.15);
}

.msg-bubble-ai {
  background: var(--bg-elevated);
  color: #1c1917;
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  color: #44403c;
  font-weight: 400;
}

/* Chat Input Spacer */
.chat-input-spacer {
  height: 40rpx;
}

/* Fixed Chat Input Footer */
.chat-input-footer {
  position: fixed;
  bottom: calc(88rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 50;
  background: rgba(250, 249, 247, 0.92);
  backdrop-filter: saturate(200%) blur(40rpx);
  -webkit-backdrop-filter: saturate(200%) blur(40rpx);
  border-top: 1rpx solid rgba(28, 25, 23, 0.04);
  padding: 20rpx 40rpx 12rpx;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.chat-input-footer-focused {
  background: rgba(250, 249, 247, 0.98);
}

.chat-input-box {
  background: var(--bg-elevated);
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  padding: 8rpx 8rpx 8rpx 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  transition: all 0.3s ease;
}

.chat-input-footer-focused .chat-input-box {
  border-color: rgba(196, 113, 90, 0.3);
  box-shadow: 0 0 0 4rpx rgba(196, 113, 90, 0.06);
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: #1c1917;
  padding: 16rpx 12rpx;
  background: transparent;
}

.input-placeholder {
  color: #78716c;
}

.send-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(196, 113, 90, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s var(--ease-spring);
}

.send-btn-active {
  background: linear-gradient(135deg, #c4715a, #d4a574);
  box-shadow: 0 4rpx 16rpx rgba(196, 113, 90, 0.25);
}

.send-btn-active:active {
  transform: scale(0.9);
}

.send-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #fff;
  border-right: 2rpx solid #fff;
  transform: rotate(45deg);
  margin-left: -2rpx;
}

.footer-safe-area {
  height: env(safe-area-inset-bottom);
}

/* ═══════════════════════════════════════
   MEMORY VIEW
   ═══════════════════════════════════════ */
.memory-view {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.category-bar {
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 14rpx;
  padding-bottom: 8rpx;
}

.category-chip {
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 400;
  background: rgba(28, 25, 23, 0.04);
  color: #57534e;
  white-space: nowrap;
  border: 1rpx solid rgba(28, 25, 23, 0.08);
  transition: all 0.3s var(--ease-spring);
}

.category-chip:active {
  transform: scale(0.95);
}

.category-chip-active {
  background: rgba(196, 113, 90, 0.1);
  color: var(--accent);
  border-color: rgba(196, 113, 90, 0.25);
  font-weight: 500;
}

.insight-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.insight-card {
  padding: 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
  transition: all 0.3s ease;
}

.insight-card:active {
  opacity: 0.7;
  transform: translateX(8rpx);
}

.insight-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.insight-date {
  font-size: 20rpx;
  color: #78716c;
  font-weight: 400;
  letter-spacing: 0.04em;
}

.insight-title {
  color: #1c1917;
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 0.01em;
}

.insight-content {
  line-height: 1.8;
  font-size: 26rpx;
  color: #57534e;
  font-weight: 400;
}

.insight-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.tag-primary {
  background: rgba(196, 113, 90, 0.12);
  color: rgba(196, 113, 90, 0.8);
}

.tag-secondary {
  background: rgba(127, 176, 105, 0.12);
  color: rgba(127, 176, 105, 0.8);
}

.tag-tertiary {
  background: rgba(28, 25, 23, 0.06);
  color: #78716c;
}

/* ═══════════════════════════════════════
   ARCHIVE VIEW
   ═══════════════════════════════════════ */
.archive-view {
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.archive-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.section-title {
  font-size: 20rpx;
  font-weight: 500;
  color: #78716c;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding-left: 4rpx;
}

.about-card {
  padding: 0 0 0 24rpx;
  position: relative;
}

.about-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 2rpx;
  background: linear-gradient(180deg, rgba(196, 113, 90, 0.5), rgba(196, 113, 90, 0.05));
}

.about-text {
  font-size: 28rpx;
  line-height: 2;
  color: #44403c;
  font-weight: 400;
}

.personality-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.personality-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(28, 25, 23, 0.04);
  border-left: 3rpx solid rgba(196, 113, 90, 0.4);
  transition: transform 0.2s var(--ease-spring);
}

.personality-item:active {
  transform: scale(0.98);
}

.personality-item:nth-child(2) { border-left-color: rgba(127, 176, 105, 0.5); }
.personality-item:nth-child(3) { border-left-color: rgba(212, 165, 116, 0.5); }
.personality-item:nth-child(4) { border-left-color: rgba(139, 157, 195, 0.5); }

.personality-name {
  font-size: 28rpx;
  font-weight: 400;
  color: #1c1917;
}

.personality-desc {
  font-size: 26rpx;
  line-height: 1.7;
  color: #57534e;
  font-weight: 400;
}

.traits-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trait-item {
  padding: 10rpx 22rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 400;
  transition: all 0.2s ease;
}

.trait-item:active {
  transform: scale(0.95);
}

.trait-warm {
  background: rgba(196, 113, 90, 0.1);
  color: rgba(196, 113, 90, 0.8);
  border: 1rpx solid rgba(196, 113, 90, 0.15);
}

.trait-sun {
  background: rgba(212, 165, 116, 0.1);
  color: rgba(212, 165, 116, 0.8);
  border: 1rpx solid rgba(212, 165, 116, 0.15);
}

.trait-night {
  background: rgba(139, 157, 195, 0.1);
  color: rgba(139, 157, 195, 0.8);
  border: 1rpx solid rgba(139, 157, 195, 0.15);
}

.trait-mint {
  background: rgba(127, 176, 105, 0.1);
  color: rgba(127, 176, 105, 0.8);
  border: 1rpx solid rgba(127, 176, 105, 0.15);
}

.trait-bloom {
  background: rgba(186, 130, 150, 0.1);
  color: rgba(186, 130, 150, 0.8);
  border: 1rpx solid rgba(186, 130, 150, 0.15);
}

.trait-sky {
  background: rgba(120, 160, 200, 0.1);
  color: rgba(120, 160, 200, 0.8);
  border: 1rpx solid rgba(120, 160, 200, 0.15);
}

.match-card-simple {
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
  transition: all 0.2s ease;
}

.match-card-simple:active {
  opacity: 0.7;
  transform: translateX(8rpx);
}

.match-avatar-simple {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(212, 165, 116, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1rpx solid rgba(212, 165, 116, 0.15);
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(212, 165, 116, 0.7);
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.match-name {
  font-size: 28rpx;
  font-weight: 400;
  color: #1c1917;
}

.match-desc {
  font-size: 24rpx;
  color: #78716c;
  line-height: 1.6;
  font-weight: 400;
}

/* ═══════════════════════════════════════
   Animations
   ═══════════════════════════════════════ */
@keyframes msgSlideInRight {
  from { opacity: 0; transform: translateX(30rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes msgSlideInLeft {
  from { opacity: 0; transform: translateX(-30rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* ═══════════════════════════════════════
   Insight Hint
   ═══════════════════════════════════════ */
.insight-hint {
  font-size: 20rpx;
  color: rgba(28, 25, 23, 0.06);
  margin-top: 4rpx;
}

/* ═══════════════════════════════════════
   Edit Modal
   ═══════════════════════════════════════ */
.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(250, 249, 247, 0.7);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  animation: fadeIn 0.25s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-dialog {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 32rpx;
  width: 100%;
  max-width: 600rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  box-shadow: 0 24rpx 80rpx rgba(196, 113, 90, 0.1), 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: modalSlideUp 0.4s var(--ease-out-expo) both;
}

@keyframes modalSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-header {
  font-size: 32rpx;
  font-weight: 400;
  color: #1c1917;
  text-align: center;
  letter-spacing: 0.04em;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-input {
  background: rgba(28, 25, 23, 0.04);
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1c1917;
  box-sizing: border-box;
  width: 100%;
  height: 80rpx;
}

.modal-textarea {
  background: rgba(28, 25, 23, 0.04);
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1c1917;
  height: 240rpx;
  line-height: 1.7;
  box-sizing: border-box;
  width: 100%;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.modal-btn {
  padding: 16rpx 36rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
}

.modal-btn.cancel {
  color: #57534e;
  background: rgba(28, 25, 23, 0.04);
}

.modal-btn.confirm {
  color: #fff;
  background: linear-gradient(135deg, #c4715a, #d4a574);
  box-shadow: 0 4rpx 16rpx rgba(196, 113, 90, 0.25);
}

.modal-btn:active {
  transform: scale(0.96);
}
