.page {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
  overflow: hidden;
}

/* ═══════════════════════════════════════
   Ambient Background Layer
   ═══════════════════════════════════════ */

.ambient-glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
  z-index: 0;
  will-change: transform;
}

.ambient-glow-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.06) 0%, transparent 65%);
  top: -180rpx;
  right: -180rpx;
  animation: meshFloat1 14s ease-in-out infinite;
}

.ambient-glow-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(127, 176, 105, 0.04) 0%, transparent 65%);
  bottom: 200rpx;
  left: -200rpx;
  animation: meshFloat2 18s ease-in-out infinite;
}

.ambient-gradient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(180deg, rgba(196, 113, 90, 0.03) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ═══════════════════════════════════════
   Content Layer
   ═══════════════════════════════════════ */

.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 24rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
}

/* ═══════════════════════════════════════
   Tab Switcher
   ═══════════════════════════════════════ */

.tab-switcher {
  position: relative;
  display: flex;
  background: var(--bg-surface);
  border-radius: var(--radius-full);
  padding: 6rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.04);
  overflow: hidden;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.03);
}

.tab-slider {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: calc((100% - 12rpx) / 3);
  height: calc(100% - 12rpx);
  background: var(--bg-elevated);
  border-radius: var(--radius-full);
  transition: transform 0.45s var(--ease-spring);
  box-shadow: var(--shadow-sm);
}

.tab-pill {
  flex: 1;
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  transition: color 0.3s var(--ease-smooth), transform 0.3s var(--ease-spring);
  letter-spacing: 0.02em;
}

.tab-pill:active {
  transform: scale(0.95);
}

.tab-pill-active {
  color: var(--accent);
  font-weight: 600;
}

/* ═══════════════════════════════════════
   CHAT VIEW
   ═══════════════════════════════════════ */

.chat-view {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  min-height: 60vh;
}

/* Chat Status Bar */
.chat-status-bar {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 32rpx 24rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.status-num {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.status-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.status-divider {
  width: 1rpx;
  height: 40rpx;
  background: var(--border-subtle);
}

/* Messages */
.messages {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  flex: 1;
  justify-content: flex-end;
  padding-bottom: 24rpx;
}

.msg-row {
  display: flex;
  width: 100%;
  opacity: 0;
}

.msg-user {
  justify-content: flex-end;
  animation: msgSlideInRight 0.5s var(--ease-out-expo) both;
}

.msg-ai {
  justify-content: flex-start;
  gap: 14rpx;
  animation: msgSlideInLeft 0.5s var(--ease-out-expo) both;
}

.ai-avatar-small {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  margin-top: 8rpx;
  border: 1rpx solid var(--border-subtle);
}

.msg-bubble {
  max-width: 78%;
  padding: 24rpx 28rpx;
}

.msg-bubble-user {
  background: var(--bg-surface);
  color: var(--text-primary);
  border-radius: var(--radius-lg) var(--radius-lg) 8rpx var(--radius-lg);
  border: 1rpx solid var(--border-subtle);
}

.msg-bubble-ai {
  background: var(--bg-elevated);
  color: var(--text-primary);
  border-radius: 8rpx var(--radius-lg) var(--radius-lg) var(--radius-lg);
  border: 1rpx solid var(--border-subtle);
  box-shadow: var(--shadow-sm);
  position: relative;
}

.msg-bubble-ai::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(196, 113, 90, 0.1), transparent 60%);
  border-radius: 8rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.65;
  white-space: pre-wrap;
  color: var(--text-secondary);
}

/* Chat Input */
.chat-input-area {
  padding: 24rpx 0 0;
}

.chat-input-box {
  background: var(--bg-elevated);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  padding: 8rpx 8rpx 8rpx 24rpx;
  border: 1rpx solid var(--border-subtle);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-smooth);
}

.chat-input-box-focused {
  border-color: rgba(196, 113, 90, 0.3);
  box-shadow: var(--shadow-md), 0 0 0 4rpx rgba(196, 113, 90, 0.06);
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 16rpx 12rpx;
  background: transparent;
}

.input-placeholder {
  color: var(--text-muted);
}

.send-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--accent-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(196, 113, 90, 0.2);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.send-btn:active {
  transform: scale(0.9);
}

.send-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #fff;
  border-right: 2rpx solid #fff;
  transform: rotate(45deg);
  margin-left: -2rpx;
}

/* ═══════════════════════════════════════
   MEMORY VIEW
   ═══════════════════════════════════════ */

.memory-view {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.category-bar {
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 14rpx;
  padding-bottom: 8rpx;
}

.category-chip {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  font-weight: 500;
  background: var(--bg-elevated);
  color: var(--text-tertiary);
  white-space: nowrap;
  border: 1rpx solid var(--border-subtle);
  transition: all 0.3s var(--ease-spring);
  box-shadow: var(--shadow-sm);
}

.category-chip:active {
  transform: scale(0.95);
}

.category-chip-active {
  background: rgba(196, 113, 90, 0.1);
  color: var(--accent);
  border-color: rgba(196, 113, 90, 0.2);
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(196, 113, 90, 0.1);
}

.insight-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.insight-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border-subtle);
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-smooth);
}

.insight-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-md);
}

.insight-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.insight-date {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.insight-title {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
}

.insight-content {
  line-height: 1.7;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.insight-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(196, 113, 90, 0.1);
  color: var(--accent);
}

.tag-secondary {
  background: rgba(127, 176, 105, 0.1);
  color: var(--success);
}

.tag-tertiary {
  background: rgba(168, 162, 158, 0.08);
  color: var(--text-secondary);
}

/* ═══════════════════════════════════════
   ARCHIVE VIEW
   ═══════════════════════════════════════ */

.archive-view {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.archive-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-tertiary);
  letter-spacing: 0.08em;
  padding-left: 4rpx;
}

.about-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  border: 1rpx solid var(--border-subtle);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.about-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  background: var(--accent-gradient);
  border-radius: 0 4rpx 4rpx 0;
}

.about-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.personality-card {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: var(--shadow-sm);
}

.personality-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  background: var(--bg-base);
  border-left: 4rpx solid var(--accent);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.personality-item:active {
  transform: scale(0.98);
}

.personality-item:nth-child(2) { border-left-color: var(--success); }
.personality-item:nth-child(3) { border-left-color: var(--accent-warm); }
.personality-item:nth-child(4) { border-left-color: #8b9dc3; }

.personality-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.personality-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.traits-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.trait-item {
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.trait-item:active {
  transform: scale(0.95);
}

.trait-warm {
  background: rgba(196, 113, 90, 0.1);
  color: #c4715a;
  border: 1rpx solid rgba(196, 113, 90, 0.18);
  box-shadow: 0 2rpx 8rpx rgba(196, 113, 90, 0.08);
}

.trait-sun {
  background: rgba(212, 165, 116, 0.12);
  color: #b8860b;
  border: 1rpx solid rgba(212, 165, 116, 0.22);
  box-shadow: 0 2rpx 8rpx rgba(212, 165, 116, 0.08);
}

.trait-night {
  background: rgba(107, 114, 142, 0.1);
  color: #5a5f73;
  border: 1rpx solid rgba(107, 114, 142, 0.18);
  box-shadow: 0 2rpx 8rpx rgba(107, 114, 142, 0.06);
}

.trait-mint {
  background: rgba(127, 176, 105, 0.1);
  color: #5a8f4a;
  border: 1rpx solid rgba(127, 176, 105, 0.18);
  box-shadow: 0 2rpx 8rpx rgba(127, 176, 105, 0.08);
}

.trait-bloom {
  background: rgba(186, 130, 150, 0.1);
  color: #a06078;
  border: 1rpx solid rgba(186, 130, 150, 0.18);
  box-shadow: 0 2rpx 8rpx rgba(186, 130, 150, 0.06);
}

.trait-sky {
  background: rgba(120, 160, 200, 0.1);
  color: #4a7ab8;
  border: 1rpx solid rgba(120, 160, 200, 0.18);
  box-shadow: 0 2rpx 8rpx rgba(120, 160, 200, 0.06);
}

.match-card-simple {
  background: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.match-card-simple:active {
  transform: scale(0.98);
}

.match-avatar-simple {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(212, 165, 116, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1rpx solid rgba(212, 165, 116, 0.25);
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent-warm);
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.match-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.match-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ═══════════════════════════════════════
   Animations
   ═══════════════════════════════════════ */

@keyframes msgSlideInRight {
  from { opacity: 0; transform: translateX(30rpx) scale(0.95); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

@keyframes msgSlideInLeft {
  from { opacity: 0; transform: translateX(-30rpx) scale(0.95); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

/* ═══════════════════════════════════════
   Insight Hint
   ═══════════════════════════════════════ */

.insight-hint {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  opacity: 0.6;
}

/* ═══════════════════════════════════════
   Edit Modal
   ═══════════════════════════════════════ */

.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(10, 8, 6, 0.45);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  animation: fadeIn 0.25s var(--ease-smooth) both;
}

.modal-dialog {
  background: var(--bg-elevated);
  border-radius: var(--radius-xl);
  padding: 40rpx 32rpx 32rpx;
  width: 100%;
  max-width: 600rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: var(--shadow-xl);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: scaleInBounce 0.4s var(--ease-out-expo) both;
}

.modal-header {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  letter-spacing: -0.01em;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-input {
  background: var(--bg-base);
  border: 1rpx solid var(--border-subtle);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  width: 100%;
  height: 80rpx;
}

.modal-textarea {
  background: var(--bg-base);
  border: 1rpx solid var(--border-subtle);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 240rpx;
  line-height: 1.6;
  box-sizing: border-box;
  width: 100%;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.modal-btn {
  padding: 16rpx 36rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.modal-btn.cancel {
  color: var(--text-secondary);
  background: var(--bg-surface);
}

.modal-btn.confirm {
  color: #ffffff;
  background: var(--accent-gradient);
  box-shadow: 0 4rpx 12rpx rgba(196, 113, 90, 0.2);
}

.modal-btn:active {
  transform: scale(0.96);
}
