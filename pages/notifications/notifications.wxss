/* ── Page ── */
.notifications-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.sub-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
  background: rgba(250, 249, 247, 0.85);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid var(--border-subtle);
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid var(--text-primary);
  border-bottom: 3rpx solid var(--text-primary);
  transform: rotate(45deg);
}

.sub-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.header-action {
  padding: 12rpx 16rpx;
  margin-right: -16rpx;
}

.clear-text {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-tertiary);
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ── Filter Bar ── */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0 16rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 9999rpx;
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-subtle);
  transition: all 0.2s var(--ease-out-expo);
}

.filter-item:active {
  transform: scale(0.95);
}

.filter-active {
  background: var(--text-primary);
  border-color: var(--text-primary);
}

.filter-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: color 0.2s ease;
}

.filter-active .filter-label {
  color: var(--bg-base);
  font-weight: 600;
}

.filter-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.filter-dot-follow {
  background: var(--success);
}

.filter-dot-comment {
  background: #4a7ab8;
}

.filter-dot-reply {
  background: var(--accent);
}

/* ── Notification List ── */
.notification-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notification-item {
  position: relative;
  background: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  transition: background-color var(--duration-fast) ease;
}

.notification-item:active {
  background: rgba(28, 25, 23, 0.03);
}

.notification-unread {
  border-color: rgba(196, 113, 90, 0.12);
  background: linear-gradient(135deg, rgba(196, 113, 90, 0.02) 0%, transparent 60%);
}

.notification-unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 3rpx;
  background: var(--accent);
  border-radius: 0 4rpx 4rpx 0;
}

.notification-main {
  display: flex;
  gap: 20rpx;
}

/* Avatar */
.notification-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.notification-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.notification-type-icon {
  position: absolute;
  bottom: -2rpx;
  right: -2rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
}

.notification-type-icon.type-follow {
  background: var(--success);
}

.notification-type-icon.type-comment {
  background: #4a7ab8;
}

.notification-type-icon.type-reply {
  background: var(--accent);
}

/* Type icons with CSS shapes */
.type-follow::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid #ffffff;
  border-right: 2rpx solid #ffffff;
  transform: translateY(1rpx) rotate(-45deg);
}

.type-comment::before {
  content: '';
  width: 10rpx;
  height: 8rpx;
  border: 1.5rpx solid #ffffff;
  border-radius: 3rpx 3rpx 3rpx 0;
}

.type-reply::before {
  content: '';
  width: 10rpx;
  height: 6rpx;
  border-bottom: 1.5rpx solid #ffffff;
  border-left: 1.5rpx solid #ffffff;
  transform: rotate(-45deg) translateX(1rpx);
}

/* Body */
.notification-body {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
  padding-top: 4rpx;
}

.notification-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.notification-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.notification-time {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.notification-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.notification-detail {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
  background: var(--bg-base);
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  margin-top: 4rpx;
  border: 1rpx solid var(--border-subtle);
}

/* ── Empty State ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
  gap: 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 2rpx dashed var(--border-medium);
  position: relative;
}

.bell-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%);
  width: 40rpx;
  height: 48rpx;
  background: var(--border-medium);
  border-radius: 24rpx 24rpx 4rpx 4rpx;
}

.bell-icon::after {
  content: '';
  position: absolute;
  bottom: 28rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 12rpx;
  background: var(--border-medium);
  border-radius: 50%;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ── List End ── */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx 0;
}

.list-end-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-subtle) 50%, transparent 100%);
  max-width: 120rpx;
}

.list-end-text {
  color: var(--text-muted);
  font-size: 22rpx;
}

/* ── Skeleton Screen ── */
.skeleton-wrap {
  padding: 24rpx 32rpx;
}

.skeleton-notification {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--border-subtle);
  margin-right: 20rpx;
  flex-shrink: 0;
  animation: skeleton-shimmer 1.4s ease infinite;
}

.skeleton-body {
  flex: 1;
  padding-top: 8rpx;
}

.skeleton-line {
  height: 18rpx;
  background: var(--border-subtle);
  border-radius: 6rpx;
  margin-bottom: 12rpx;
  animation: skeleton-shimmer 1.4s ease infinite;
}

.skeleton-line-short {
  width: 35%;
}

.skeleton-line-shorter {
  width: 25%;
}

.skeleton-line-medium {
  width: 60%;
}

@keyframes skeleton-shimmer {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

/* ── Error State ── */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--border-subtle);
  margin-bottom: 32rpx;
  position: relative;
}

.error-icon::before,
.error-icon::after {
  content: '';
  position: absolute;
  background: var(--text-muted);
  border-radius: 2rpx;
}

.error-icon::before {
  width: 8rpx;
  height: 40rpx;
  top: 30rpx;
  left: 50%;
  transform: translateX(-50%);
}

.error-icon::after {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.error-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 40rpx;
}

.error-retry {
  padding: 18rpx 56rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--accent);
}

.error-retry:active {
  opacity: 0.85;
  transform: scale(0.96);
}
