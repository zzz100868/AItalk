.page {
  min-height: 100vh;
  background: var(--bg-base);
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
}

.content-inner {
  padding: 24rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ── Tab Switcher ── */
.tab-switcher {
  display: flex;
  justify-content: center;
  background: var(--bg-elevated);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--border-subtle);
}

.tab-pill {
  padding: 14rpx 36rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  transition: all var(--duration-normal) var(--ease-out-expo);
}

.tab-pill-active {
  background: var(--bg-surface);
  color: var(--text-primary);
}

/* ── Archive Card ── */
.archive-card {
  background: var(--bg-elevated);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.archive-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.archive-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.icon-dimension {
  background: rgba(196, 113, 90, 0.15);
  border: 1rpx solid rgba(196, 113, 90, 0.25);
}
.icon-dimension::before {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid var(--accent);
  border-radius: 4rpx;
  transform: rotate(45deg);
}

.icon-trait {
  background: rgba(127, 176, 105, 0.15);
  border: 1rpx solid rgba(127, 176, 105, 0.25);
}
.icon-trait::before {
  content: '';
  width: 14rpx;
  height: 14rpx;
  background: var(--success);
  border-radius: 9999rpx;
}

.icon-match {
  background: rgba(212, 165, 116, 0.15);
  border: 1rpx solid rgba(212, 165, 116, 0.25);
}
.icon-match::before {
  content: '';
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid var(--accent-warm);
  border-radius: 4rpx;
  transform: rotate(45deg);
}

.archive-title {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* ── Dimensions ── */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dimension {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dimension-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.dimension-value {
  font-size: 24rpx;
  font-weight: 600;
}

.value-primary { color: var(--accent); }
.value-secondary { color: var(--success); }
.value-tertiary { color: var(--text-secondary); }

.progress-track {
  width: 100%;
  height: 6rpx;
  background: var(--border-subtle);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 3rpx;
  transition: width 1s var(--ease-out-expo);
}

.bar-primary { background: linear-gradient(90deg, var(--accent), rgba(196, 113, 90, 0.7)); }
.bar-secondary { background: linear-gradient(90deg, var(--success), rgba(127, 176, 105, 0.7)); }
.bar-tertiary { background: linear-gradient(90deg, var(--text-secondary), rgba(168, 162, 158, 0.6)); }

/* ── Traits ── */
.trait-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.trait {
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid var(--border-subtle);
}

.trait-primary {
  background: rgba(196, 113, 90, 0.12);
  color: var(--accent);
  border-color: rgba(196, 113, 90, 0.2);
}

.trait-secondary {
  background: rgba(127, 176, 105, 0.12);
  color: var(--success);
  border-color: rgba(127, 176, 105, 0.2);
}

.trait-tertiary {
  background: rgba(168, 162, 158, 0.1);
  color: var(--text-secondary);
  border-color: rgba(168, 162, 158, 0.15);
}

.trait-name {
  font-size: 26rpx;
  font-weight: 500;
}

/* ── Match Card ── */
.match-card {
  position: relative;
  overflow: hidden;
}

.match-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--bg-surface);
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--border-subtle);
}

.match-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(212, 165, 116, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1rpx solid rgba(212, 165, 116, 0.25);
}

.match-avatar-letter {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent-warm);
}

.match-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.match-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.match-desc {
  font-size: 24rpx;
}

.match-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid var(--text-muted);
  border-right: 2rpx solid var(--text-muted);
  transform: rotate(45deg);
  flex-shrink: 0;
}
