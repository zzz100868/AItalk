.action-count {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
}

/* ── Comments Section ── */
.comments-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 0;
  overflow: hidden;
  transform-origin: top;
  max-height: 0;
  opacity: 0;
  transform: translateY(-12rpx);
  transition: max-height 0.4s var(--ease-out-expo),
              opacity 0.3s var(--ease-smooth),
              transform 0.4s var(--ease-out-expo),
              margin-top 0.3s ease;
}

.comments-section.is-expanded {
  max-height: 1200rpx;
  opacity: 1;
  transform: translateY(0);
  margin-top: 8rpx;
}

.comments-divider {
  height: 1rpx;
  background: linear-gradient(90deg, var(--border-subtle) 0%, transparent 100%);
  margin: 4rpx 0;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  animation: fadeInUp 0.3s var(--ease-out-expo) both;
}

.comment-item:nth-child(1) { animation-delay: 0.05s; }
.comment-item:nth-child(2) { animation-delay: 0.1s; }
.comment-item:nth-child(3) { animation-delay: 0.15s; }
.comment-item:nth-child(4) { animation-delay: 0.2s; }
.comment-item:nth-child(5) { animation-delay: 0.25s; }

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.comment-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.comment-author {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.comment-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.comment-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-top: 8rpx;
}

.comment-input {
  flex: 1;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  border-radius: 9999rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  transition: border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease;
}

.comment-input:focus {
  border-color: var(--border-medium);
}

.comment-placeholder {
  color: var(--text-muted);
}

/* ── Comment Header Row ── */
.comment-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding: 4rpx 0;
  border-radius: 8rpx;
  transition: background 0.15s ease;
}

.comment-text:active {
  background: var(--bg-surface);
}

/* ── Replies ── */
.replies-wrap {
  display: flex;
  flex-direction: column;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  background: var(--bg-base);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-subtle);
}

.reply-item {
  display: flex;
  gap: 10rpx;
  align-items: flex-start;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.reply-item-last {
  border-bottom: none;
}

.reply-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reply-content {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
}

.reply-meta {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.reply-author {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.reply-target {
  font-size: 22rpx;
  color: var(--text-muted);
}

.reply-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding: 4rpx 0;
  border-radius: 8rpx;
  transition: background 0.15s ease;
}

.reply-text:active {
  background: var(--bg-surface);
}

/* ── Reply Hint ── */
.reply-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: var(--accent-dim);
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 500;
}

.reply-hint-close {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-x {
  width: 16rpx;
  height: 16rpx;
  position: relative;
}

.close-x::before,
.close-x::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 2rpx;
  background: var(--accent);
  border-radius: 2rpx;
}

.close-x::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.close-x::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}
