@import '../../styles/shared.wxss';

/* ── Page ── */
.user-home-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.user-home-header .header-left {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ── Profile Hero ── */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 16rpx;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-frame {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  z-index: 1;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 2rpx solid rgba(28, 25, 23, 0.12);
  position: relative;
  z-index: 1;
}

.avatar-ring {
  position: absolute;
  inset: -6rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.25);
  animation: ringPulse 3s ease-in-out infinite;
}

.avatar-ring-outer {
  position: absolute;
  inset: -14rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.08);
  animation: ringPulse 3s ease-in-out infinite;
  animation-delay: 1.5s;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.03); opacity: 1; }
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.profile-handle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  font-family: 'SF Mono', monospace;
  letter-spacing: 0.04em;
}

.profile-bio {
  margin-top: 4rpx;
  max-width: 80%;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

/* ── Stats ── */
.stats-card {
  background: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(196, 113, 90, 0.15) 50%, transparent 100%);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-num {
  color: var(--text-primary);
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-tertiary);
  letter-spacing: 0.06em;
}

.stat-divider {
  width: 1rpx;
  height: 36rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(28, 25, 23, 0.08) 50%, transparent 100%);
}

/* ── Action Bar ── */
.action-bar {
  display: flex;
  justify-content: center;
  padding: 4rpx 0 8rpx;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  max-width: 320rpx;
  padding: 20rpx 0;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--accent);
  text-align: center;
  transition: all var(--duration-fast) ease;
}

.action-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.action-btn-active {
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 1rpx solid var(--border-medium);
}

.action-btn-secondary {
  background: var(--bg-surface);
  color: var(--text-primary);
  border: 1rpx solid var(--border-medium);
}

.action-btn-chat {
  background: var(--accent);
  color: #ffffff;
}

.action-btn-danger {
  background: var(--error-dim);
  color: var(--error);
  border: 1rpx solid rgba(196, 90, 90, 0.2);
}

.blocked-icon {
  background: var(--error-dim);
  border: 2rpx dashed rgba(196, 90, 90, 0.3);
}

.blocked-icon::before,
.blocked-icon::after {
  background: var(--error);
}

.blocked-icon::before {
  width: 4rpx;
  height: 40rpx;
  transform: translate(-50%, -50%) rotate(45deg);
}

.blocked-icon::after {
  width: 40rpx;
  height: 4rpx;
  transform: translate(-50%, -50%) rotate(45deg);
}

/* ── Menu Section ── */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 4rpx;
}

.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(28, 25, 23, 0.06) 0%, transparent 100%);
}

/* ── Empty State ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
  gap: 20rpx;
}

.empty-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 2rpx dashed var(--border-medium);
  position: relative;
}

.empty-icon::before,
.empty-icon::after {
  content: '';
  position: absolute;
  background: var(--border-medium);
  border-radius: 2rpx;
}

.empty-icon::before {
  width: 4rpx;
  height: 32rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-icon::after {
  width: 32rpx;
  height: 4rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ── Feed Grid ── */
.feed-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ── Post Card ── */
.post-card {
  position: relative;
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.02) 0%, transparent 50%);
  pointer-events: none;
  border-radius: inherit;
}

/* ── Post Header ── */
.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.post-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.post-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.post-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ── Post Body ── */
.post-body {
  display: flex;
  flex-direction: column;
}

.post-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

/* ── Post Images ── */
.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 4rpx;
}

.post-image {
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.post-image-single {
  grid-column: span 1;
  height: 280rpx;
}

/* ── Post Actions ── */
.post-actions {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding-top: 4rpx;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
