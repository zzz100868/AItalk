@import '../../styles/shared.wxss';

/* ── Page & Ambient ── */
.explore-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

.ambient-glow {
  position: fixed;
  border-radius: 50%;
  filter: blur(120rpx);
  opacity: 0.2;
  pointer-events: none;
  z-index: 0;
}

.ambient-glow-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.12) 0%, transparent 70%);
  top: -200rpx;
  left: -150rpx;
}

.ambient-glow-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(139, 120, 160, 0.1) 0%, transparent 70%);
  bottom: 100rpx;
  right: -200rpx;
}

/* ── Feed ── */
.feed {
  position: relative;
  z-index: 1;
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
}

.feed-inner {
  padding: 24rpx 32rpx 180rpx;
}

/* ── Magazine Header ── */
.section-header {
  margin-bottom: 56rpx;
  padding-top: 16rpx;
  position: relative;
}

.section-title-wrap {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.03em;
  line-height: 1.05;
  margin-bottom: 12rpx;
}

.section-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  letter-spacing: 0.02em;
  font-weight: 400;
}

.section-header-right {
  position: absolute;
  top: 24rpx;
  right: 0;
}

.bell-btn {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-subtle);
}

.bell-icon {
  width: 28rpx;
  height: 32rpx;
  background: var(--text-tertiary);
  border-radius: 16rpx 16rpx 4rpx 4rpx;
  position: relative;
}

.bell-icon::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: var(--text-tertiary);
  border-radius: 50%;
}

.bell-dot {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--accent);
  border: 2rpx solid var(--bg-base);
}

.section-divider {
  height: 1rpx;
  background: linear-gradient(90deg, var(--border-medium) 0%, var(--border-subtle) 60%, transparent 100%);
}

/* ── Feed Grid ── */
.feed-grid {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ── Post Card ── */
.post-card {
  position: relative;
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  transition: transform var(--duration-fast) var(--ease-out-expo),
              box-shadow var(--duration-normal) var(--ease-smooth),
              opacity var(--duration-fast) ease;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.02) 0%, transparent 50%);
  pointer-events: none;
  border-radius: inherit;
}

.post-card:active {
  transform: scale(0.985);
  opacity: 0.9;
}

.post-left {
  margin-right: 20rpx;
}

.post-right {
  margin-left: 20rpx;
}

/* Featured Post */
.post-featured {
  padding: 40rpx;
  border-radius: 32rpx;
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-medium);
  gap: 24rpx;
}

.post-featured::after {
  content: '';
  position: absolute;
  left: 0;
  top: 40rpx;
  bottom: 40rpx;
  width: 4rpx;
  background: linear-gradient(180deg, var(--accent) 0%, var(--accent-warm) 100%);
  border-radius: 0 4rpx 4rpx 0;
}

.post-featured .post-text {
  font-size: 30rpx;
  line-height: 1.75;
}

.post-featured .post-avatar {
  width: 76rpx;
  height: 76rpx;
}

/* ── Post Header ── */
.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.post-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.post-card:active .post-avatar {
  transform: scale(0.95);
}

.post-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.post-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.post-more {
  display: flex;
  gap: 5rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: background var(--duration-fast) ease;
}

.post-more:active {
  background: var(--border-subtle);
}

.more-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 9999rpx;
  background: var(--text-muted);
}

/* ── Post Body ── */
.post-body {
  display: flex;
  flex-direction: column;
}

.post-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

/* ── Post Images ── */
.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 4rpx;
}

.post-image {
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.post-image-single {
  grid-column: span 1;
  height: 280rpx;
}

/* ── Post Actions ── */
.post-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 8rpx;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.action-group:active {
  transform: scale(0.88);
}

/* Share Icon */
.icon-share::before {
  content: '';
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid var(--text-muted);
  border-radius: 4rpx;
  transform: rotate(45deg);
  position: absolute;
}

.action-group:active .action-count {
  transform: scale(0.95);
}

.action-share {
  margin-left: auto;
}


/* ── Floating Action Button ── */
.fab-post {
  position: fixed;
  right: 32rpx;
  bottom: calc(130rpx + env(safe-area-inset-bottom));
  z-index: 50;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(196, 113, 90, 0.3);
  transition: all 0.25s var(--ease-out-expo);
  pointer-events: auto;
}

.fab-post:active {
  transform: scale(0.92);
  box-shadow: 0 4rpx 16rpx rgba(196, 113, 90, 0.2);
}

.fab-icon {
  width: 32rpx;
  height: 32rpx;
  position: relative;
}

.fab-icon::before,
.fab-icon::after {
  content: '';
  position: absolute;
  background: #ffffff;
  border-radius: 2rpx;
}

.fab-icon::before {
  width: 4rpx;
  height: 32rpx;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

.fab-icon::after {
  width: 32rpx;
  height: 4rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

/* ── Post Panel Overlay ── */
.post-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(6rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.post-modal {
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  max-width: 640rpx;
  max-height: 80vh;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: modalIn 0.3s var(--ease-out-expo) both;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.95) translateY(20rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.post-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.post-modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s ease;
}

.post-modal-close:active {
  background: var(--bg-surface);
}

.close-icon {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.close-icon::before,
.close-icon::after {
  content: '';
  position: absolute;
  width: 2rpx;
  height: 20rpx;
  background: var(--text-tertiary);
  border-radius: 1rpx;
  left: 50%;
  top: 0;
}

.close-icon::before {
  transform: rotate(45deg);
}

.close-icon::after {
  transform: rotate(-45deg);
}

.post-modal-textarea {
  width: 100%;
  min-height: 140rpx;
  max-height: 320rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: var(--text-primary);
  background: var(--bg-base);
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--border-subtle);
}

.post-placeholder {
  color: var(--text-muted);
  font-size: 30rpx;
}

/* ── Image Upload ── */
.image-upload-area {
  width: 100%;
}

.image-scroll {
  white-space: nowrap;
}

.image-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.image-item {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
}

.image-preview {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.image-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(28, 25, 23, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 14rpx;
  height: 14rpx;
  position: relative;
}

.delete-icon::before,
.delete-icon::after {
  content: '';
  position: absolute;
  width: 2rpx;
  height: 14rpx;
  background: #ffffff;
  border-radius: 1rpx;
  left: 50%;
  top: 0;
}

.delete-icon::before {
  transform: rotate(45deg);
}

.delete-icon::after {
  transform: rotate(-45deg);
}

.image-add {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: var(--bg-base);
  border: 2rpx dashed var(--border-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.image-add:active {
  background: var(--bg-surface);
  border-color: var(--accent);
}

.add-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.add-icon::before,
.add-icon::after {
  content: '';
  position: absolute;
  background: var(--text-muted);
  border-radius: 2rpx;
}

.add-icon::before {
  width: 4rpx;
  height: 36rpx;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
}

.add-icon::after {
  width: 36rpx;
  height: 4rpx;
  top: 50%;
  left: 0;
  transform: translateY(-50%);
}

/* ── Post Modal Footer ── */
.post-modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-char-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.post-submit-btn {
  padding: 16rpx 40rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--border-subtle);
  transition: all 0.2s ease;
}

.post-submit-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.post-submit-active {
  background: var(--accent);
}

.post-submit-active:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.post-submit-loading {
  opacity: 0.7;
  pointer-events: none;
}
