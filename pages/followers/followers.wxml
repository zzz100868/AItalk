<view class="page">
  <!-- Header -->
  <view class="sub-header">
    <view class="back-btn" bindtap="goBack">
      <view class="back-arrow"></view>
    </view>
    <text class="sub-title">粉丝</text>
    <view class="spacer"></view>
  </view>

  <scroll-view scroll-y class="content">
    <view class="content-inner">
      <view class="page-header anim-fade-in-up">
        <text class="page-title display-lg">粉丝</text>
        <text class="page-subtitle body">248 位共鸣者</text>
      </view>

      <view class="follower-list">
        <view
          class="follower-item anim-fade-in-up"
          style="animation-delay: {{(index + 1) * 0.06}}s"
          wx:for="{{followers}}"
          wx:key="id"
        >
          <view class="follower-info" bindtap="goToUserHome" data-name="{{item.name}}">
            <image class="follower-avatar" src="{{item.avatar}}" mode="aspectFill"/>
            <view class="follower-meta">
              <text class="follower-name">{{item.name}}</text>
              <text class="follower-handle">{{item.handle}}</text>
            </view>
          </view>
          <view
            class="follow-btn {{item.status === 'mutual' ? 'follow-btn-mutual' : 'follow-btn-action'}}"
            bindtap="toggleFollow"
            data-id="{{item.id}}"
          >
            {{item.status === 'mutual' ? '互关' : '回关'}}
          </view>
        </view>
      </view>

      <view class="list-end">
        <view class="list-end-line"></view>
        <text class="list-end-text caption">已到底部</text>
        <view class="list-end-line"></view>
      </view>
    </view>
  </scroll-view>
</view>
