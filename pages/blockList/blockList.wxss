/* ── Page ── */
.block-list-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.sub-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
  background: rgba(250, 249, 247, 0.85);
  backdrop-filter: saturate(180%) blur(24rpx);
  -webkit-backdrop-filter: saturate(180%) blur(24rpx);
  border-bottom: 1rpx solid var(--border-subtle);
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid var(--text-primary);
  border-bottom: 3rpx solid var(--text-primary);
  transform: rotate(45deg);
}

.sub-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.spacer {
  width: 56rpx;
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.page-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 16rpx;
}

.page-subtitle {
  color: var(--text-tertiary);
}

/* ── Blocked List ── */
.blocked-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.blocked-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
}

.blocked-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.blocked-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.blocked-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.blocked-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.blocked-bio {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unblock-btn {
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  background: var(--bg-surface);
  border: 1rpx solid var(--border-medium);
  flex-shrink: 0;
  transition: all var(--duration-fast) ease;
}

.unblock-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

/* ── Empty State ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
  gap: 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 2rpx dashed var(--border-medium);
  position: relative;
}

.empty-icon::before,
.empty-icon::after {
  content: '';
  position: absolute;
  background: var(--border-medium);
  border-radius: 2rpx;
}

.empty-icon::before {
  width: 4rpx;
  height: 40rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-icon::after {
  width: 40rpx;
  height: 4rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ── List End ── */
.list-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 24rpx 0;
}

.list-end-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent 0%, var(--border-subtle) 50%, transparent 100%);
  max-width: 120rpx;
}

.list-end-text {
  color: var(--text-muted);
  font-size: 22rpx;
}
