/* ── Page ── */
.edit-profile-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.edit-header .header-left {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid var(--text-primary);
  border-bottom: 3rpx solid var(--text-primary);
  transform: rotate(45deg);
}

.save-btn {
  padding: 10rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-muted);
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  transition: all var(--duration-fast) ease;
}

.save-btn-active {
  color: #ffffff;
  background: var(--accent);
  border-color: var(--accent);
}

.save-btn-active:active {
  opacity: 0.85;
  transform: scale(0.96);
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 24rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ── Avatar Section ── */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding-top: 16rpx;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  border: 2rpx solid var(--border-subtle);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.avatar-wrapper:active {
  transform: scale(0.96);
}

.edit-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-mask {
  position: absolute;
  inset: 0;
  background: rgba(28, 25, 23, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity var(--duration-fast) ease;
}

.avatar-wrapper:active .avatar-mask,
.avatar-wrapper:hover .avatar-mask {
  opacity: 1;
}

/* 小程序 hover 不生效，默认显示 mask 但降低透明度 */
.avatar-mask {
  opacity: 1;
  background: rgba(28, 25, 23, 0.18);
}

.camera-icon {
  width: 40rpx;
  height: 32rpx;
  border: 3rpx solid #ffffff;
  border-radius: 6rpx;
  position: relative;
}

.camera-icon::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 6rpx;
  background: #ffffff;
  border-radius: 3rpx 3rpx 0 0;
}

.camera-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 10rpx;
  height: 10rpx;
  background: #ffffff;
  border-radius: 9999rpx;
}

.avatar-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ── Form Card ── */
.form-card {
  background: var(--bg-elevated);
  border-radius: 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 24rpx;
}

.form-item-stack {
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-width: 120rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: right;
  min-width: 0;
}

.form-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-muted);
  text-align: right;
  font-family: 'SF Mono', monospace;
}

.form-placeholder {
  color: var(--text-muted);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  max-height: 240rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-primary);
  background: var(--bg-base);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.form-divider {
  height: 1rpx;
  margin: 0 28rpx;
  background: linear-gradient(
    90deg,
    rgba(28, 25, 23, 0.04) 0%,
    rgba(28, 25, 23, 0.08) 50%,
    rgba(28, 25, 23, 0.04) 100%
  );
}

/* ── Form Hint ── */
.form-hint {
  text-align: center;
  padding: 8rpx 40rpx;
}

.form-hint text {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}
