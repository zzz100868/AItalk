<view class="page chat-page">
  <!-- Header -->
  <view class="page-header-bar chat-header">
    <view class="header-left" bindtap="goToUserHome" data-author="林夕">
      <image class="header-avatar" src="{{userAvatar}}" mode="aspectFill" lazy-load/>
    </view>
    <text class="header-title">聊天</text>
    <view class="header-action">
      <view class="notification-dot"></view>
    </view>
  </view>

  <scroll-view scroll-y class="content safe-bottom" enable-back-to-top>
    <view class="content-inner">
      <!-- Tab Switcher -->
      <view class="chat-tab-bar">
        <view
          class="chat-tab {{activeTab === 'private' ? 'chat-tab-active' : ''}}"
          bindtap="switchTab"
          data-tab="private"
        >
          <text class="chat-tab-text">私信</text>
          <view wx:if="{{privateConversations.length > 0}}" class="chat-tab-badge">{{privateConversations.length}}</view>
        </view>
        <view
          class="chat-tab {{activeTab === 'crush' ? 'chat-tab-active' : ''}}"
          bindtap="switchTab"
          data-tab="crush"
        >
          <text class="chat-tab-text">心动匹配</text>
          <view wx:if="{{crushConversations.length > 0}}" class="chat-tab-badge">{{crushConversations.length}}</view>
        </view>
      </view>

      <!-- Private Messages -->
      <view wx:if="{{activeTab === 'private'}}">
        <view wx:if="{{privateConversations.length === 0}}" class="empty-state">
          <view class="empty-icon"></view>
          <text class="empty-title">还没有私信</text>
          <text class="empty-desc">去广场发现有趣的人吧</text>
        </view>

        <view wx:if="{{privateConversations.length > 0}}" class="conversation-list">
          <view
            class="conversation-item anim-fade-in-up"
            style="animation-delay: {{index * 0.05}}s"
            wx:for="{{privateConversations}}"
            wx:key="name"
            bindtap="goToChatDetail"
            bindlongpress="onConversationLongPress"
            data-user="{{item.name}}"
          >
            <image class="conv-avatar" src="{{item.avatar}}" mode="aspectFill" lazy-load catchtap="goToUserHome" data-author="{{item.name}}"/>
            <view class="conv-content">
              <view class="conv-top">
                <text class="conv-name">{{item.name}}</text>
                <text class="conv-time">{{item.lastTime}}</text>
              </view>
              <text class="conv-last-msg">{{item.lastContent}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Crush Matches -->
      <view wx:if="{{activeTab === 'crush'}}">
        <view wx:if="{{crushConversations.length === 0}}" class="empty-state">
          <view class="empty-icon crush-empty-icon">
            <view class="crush-heart"></view>
          </view>
          <text class="empty-title">还没有心动匹配</text>
          <text class="empty-desc">去盲盒匹配遇见有趣的灵魂</text>
        </view>

        <view wx:if="{{crushConversations.length > 0}}" class="conversation-list">
          <view
            class="conversation-item anim-fade-in-up"
            style="animation-delay: {{index * 0.05}}s"
            wx:for="{{crushConversations}}"
            wx:key="name"
            bindtap="goToChatDetail"
            bindlongpress="onConversationLongPress"
            data-user="{{item.name}}"
          >
            <image class="conv-avatar" src="{{item.avatar}}" mode="aspectFill" lazy-load catchtap="goToUserHome" data-author="{{item.name}}"/>
            <view class="conv-content">
              <view class="conv-top">
                <text class="conv-name">{{item.name}}</text>
                <text class="conv-time">{{item.lastTime}}</text>
              </view>
              <text class="conv-last-msg">{{item.lastContent}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
