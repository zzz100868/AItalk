/* ── Page ── */
.chat-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.chat-header .header-left {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.notification-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  border: 2rpx solid var(--bg-base);
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
}

/* ── Empty State ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
  gap: 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 2rpx dashed var(--border-medium);
  position: relative;
}

.empty-icon::before,
.empty-icon::after {
  content: '';
  position: absolute;
  background: var(--border-medium);
  border-radius: 2rpx;
}

.empty-icon::before {
  width: 4rpx;
  height: 40rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-icon::after {
  width: 40rpx;
  height: 4rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ── Conversation List ── */
.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.conversation-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-elevated);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-subtle);
  transition: transform 0.15s ease, background 0.15s ease;
}

.conversation-item:active {
  transform: scale(0.98);
  background: var(--bg-surface);
}

.conv-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.conv-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.conv-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.conv-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.conv-time {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.conv-last-msg {
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
