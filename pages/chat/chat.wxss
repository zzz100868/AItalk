/* ── Page ── */
.chat-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.chat-header .header-left {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

.header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.notification-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--accent);
  border: 2rpx solid var(--bg-base);
}

/* ── Tab Bar ── */
.chat-tab-bar {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 24rpx;
  background: var(--bg-elevated);
  border-radius: 16rpx;
  padding: 6rpx;
  border: 1rpx solid var(--border-subtle);
}

.chat-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-muted);
  transition: all 0.25s var(--ease-out-expo);
  position: relative;
}

.chat-tab-active {
  background: var(--bg-base);
  color: var(--text-primary);
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.chat-tab-text {
  line-height: 1;
}

.chat-tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 9999rpx;
  background: var(--accent);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
}

/* ── Empty State ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
  gap: 20rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 2rpx dashed var(--border-medium);
  position: relative;
}

.empty-icon::before,
.empty-icon::after {
  content: '';
  position: absolute;
  background: var(--border-medium);
  border-radius: 2rpx;
}

.empty-icon::before {
  width: 4rpx;
  height: 40rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-icon::after {
  width: 40rpx;
  height: 4rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.crush-empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  border-style: solid;
  border-color: rgba(196, 113, 90, 0.15);
  background: rgba(196, 113, 90, 0.04);
}

.crush-empty-icon::before,
.crush-empty-icon::after {
  display: none;
}

.crush-heart {
  width: 48rpx;
  height: 44rpx;
  background: var(--accent);
  position: relative;
  transform: rotate(-45deg);
  border-radius: 0 0 4rpx 0;
}

.crush-heart::before,
.crush-heart::after {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  background: var(--accent);
  border-radius: 50%;
}

.crush-heart::before {
  top: -24rpx;
  left: 0;
}

.crush-heart::after {
  top: 0;
  left: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ── Conversation List ── */
.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.conversation-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--bg-elevated);
  border-radius: 24rpx;
  border: 1rpx solid var(--border-subtle);
  transition: transform 0.15s ease, background 0.15s ease;
}

.conversation-item:active {
  transform: scale(0.98);
  background: var(--bg-surface);
}

.conv-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.conv-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.conv-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.conv-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.conv-time {
  font-size: 22rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.conv-last-msg {
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
