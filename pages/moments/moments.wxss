@import '../../styles/shared.wxss';

/* ── Page ── */
.moments-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Header ── */
.moments-header .header-left {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-left: -16rpx;
}

/* ── Feed ── */
.feed {
  position: relative;
  z-index: 1;
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
}

.feed-inner {
  padding: 24rpx 32rpx 180rpx;
}

/* ── Empty State ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  gap: 24rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-elevated);
  border: 2rpx dashed var(--border-medium);
  position: relative;
}

.empty-icon::before,
.empty-icon::after {
  content: '';
  position: absolute;
  background: var(--border-medium);
  border-radius: 2rpx;
}

.empty-icon::before {
  width: 4rpx;
  height: 40rpx;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.empty-icon::after {
  width: 40rpx;
  height: 4rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ── Feed Grid ── */
.feed-grid {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ── Post Card ── */
.post-card {
  position: relative;
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  transition: transform var(--duration-fast) var(--ease-out-expo),
              box-shadow var(--duration-normal) var(--ease-smooth),
              opacity var(--duration-fast) ease;
  overflow: hidden;
}

.post-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0,0,0,0.02) 0%, transparent 50%);
  pointer-events: none;
  border-radius: inherit;
}

.post-card:active {
  transform: scale(0.985);
  opacity: 0.9;
}

/* ── Post Header ── */
.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.post-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  transition: transform var(--duration-fast) var(--ease-spring);
}

.post-card:active .post-avatar {
  transform: scale(0.95);
}

.post-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.post-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.post-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.post-more {
  display: flex;
  gap: 5rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  transition: background var(--duration-fast) ease;
}

.post-more:active {
  background: var(--border-subtle);
}

.more-dot {
  width: 4rpx;
  height: 4rpx;
  border-radius: 9999rpx;
  background: var(--text-muted);
}

/* ── Post Body ── */
.post-body {
  display: flex;
  flex-direction: column;
}

.post-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

/* ── Post Images ── */
.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 8rpx;
}

.post-image {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.post-image-single {
  grid-column: span 1;
  height: 320rpx;
}

/* ── Post Actions ── */
.post-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 8rpx;
}

.action-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
  transition: transform var(--duration-fast) var(--ease-spring);
}

.action-group:active {
  transform: scale(0.88);
}

.action-group:active .action-count {
  transform: scale(0.95);
}

