.page-container {
  min-height: 100vh;
  background: var(--bg-base);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ── Ambient Background ── */
.ambient-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.ambient-orb {
  position: absolute;
  border-radius: 9999rpx;
  filter: blur(140rpx);
  opacity: 0.1;
}

.orb-1 {
  width: 700rpx;
  height: 700rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.15), transparent 70%);
  top: -15%;
  right: -25%;
}

.orb-2 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.1), transparent 70%);
  bottom: 15%;
  left: -20%;
}

.orb-3 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.08), transparent 70%);
  top: 40%;
  left: 50%;
  transform: translateX(-50%);
}

.ambient-noise {
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128rpx;
}

/* ── Main Content ── */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 160rpx 48rpx 80rpx;
  position: relative;
  z-index: 1;
}

/* ── Brand Mark ── */
.brand-mark {
  margin-bottom: 48rpx;
}

.avatar-zone {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-ring-outer {
  position: absolute;
  inset: -16rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.12);
  animation: ringPulse 3s ease-in-out infinite;
}

.avatar-ring-mid {
  position: absolute;
  inset: -8rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.06);
  animation: ringPulse 3s ease-in-out infinite 0.5s;
}

.avatar-frame {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  overflow: hidden;
  position: relative;
  border: 2rpx solid var(--border-medium);
}

.ai-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(1.05) saturate(0.9);
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.03); opacity: 1; }
}

/* ── Title Section ── */
.title-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

.brand-title {
  position: relative;
  display: flex;
  align-items: baseline;
  line-height: 1;
  z-index: 1;
}

/* 错位阴影层 */
.brand-title::before {
  content: 'AiTalk';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  font-size: 96rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--accent);
  opacity: 0.10;
  z-index: -1;
  white-space: nowrap;
}

/* 渐变装饰下划线 */
.brand-title::after {
  content: '';
  position: absolute;
  bottom: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, var(--accent-warm), transparent);
  opacity: 0.5;
}

.title-part {
  font-size: 96rpx;
  letter-spacing: 0.02em;
  line-height: 1;
}

.title-ai {
  font-weight: 700;
  color: var(--text-primary);
}

.title-talk {
  font-weight: 300;
  color: var(--accent);
  margin-left: 4rpx;
}

.brand-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 400;
  letter-spacing: 0.06em;
  margin-top: 16rpx;
}

/* ── Action Area ── */
.action-area {
  width: 100%;
  display: flex;
  justify-content: center;
}

.btn-start {
  width: 100%;
  max-width: 480rpx;
  background: var(--text-primary);
  color: var(--bg-base);
  border-radius: 9999rpx;
  padding: 32rpx 56rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-normal) var(--ease-smooth);
}

.btn-start::after { border: none; }

.btn-start:active {
  transform: scale(0.96);
}

.btn-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid var(--bg-base);
  border-right: 3rpx solid var(--bg-base);
  transform: rotate(45deg);
  opacity: 0.8;
}

/* ── Footer ── */
.landing-footer {
  position: absolute;
  bottom: 64rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

/* ── Landing-specific Animations ── */
.anim-fade-in-up {
  animation: fadeInUp var(--duration-slow) var(--ease-out-expo) both;
}

.anim-fade-in {
  animation: fadeIn var(--duration-normal) var(--ease-smooth) both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

/* ── Exit Overlay ── */
.exit-overlay {
  position: fixed;
  inset: 0;
  background: var(--bg-base);
  z-index: 100;
  animation: exitOverlayFade 0.55s var(--ease-smooth) forwards;
  pointer-events: none;
}

@keyframes exitOverlayFade {
  0% { opacity: 0; }
  60% { opacity: 1; }
  100% { opacity: 1; }
}

/* ── Exit Transition ── */
.page-container.exiting .main-content {
  animation: exitContent 0.55s var(--ease-out-expo) forwards;
}

.page-container.exiting .ambient-bg {
  animation: exitBg 0.7s var(--ease-smooth) forwards;
}

.page-container.exiting .btn-start {
  animation: exitButton 0.35s var(--ease-out-expo) forwards;
}

@keyframes exitContent {
  0% { opacity: 1; transform: scale(1) translateY(0); filter: blur(0); }
  100% { opacity: 0; transform: scale(0.9) translateY(-40rpx); filter: blur(4rpx); }
}

@keyframes exitBg {
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@keyframes exitButton {
  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(196, 113, 90, 0); }
  30% { transform: scale(0.94); box-shadow: 0 0 0 0 rgba(196, 113, 90, 0.3); }
  60% { transform: scale(1.02); box-shadow: 0 0 60rpx 20rpx rgba(196, 113, 90, 0.15); }
  100% { transform: scale(1); box-shadow: 0 0 80rpx 40rpx rgba(196, 113, 90, 0); }
}
