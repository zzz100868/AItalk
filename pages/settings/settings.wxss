/* ── Page ── */
.settings-page {
  position: relative;
  min-height: 100vh;
  background: var(--bg-base);
  overflow: hidden;
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 16rpx 32rpx 180rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ── Profile Mini ── */
.profile-mini {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  transition: background-color var(--duration-fast) ease;
}

.profile-mini:active {
  background: rgba(28, 25, 23, 0.03);
}

.mini-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.mini-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.mini-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.mini-id {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  font-family: 'SF Mono', monospace;
}

.mini-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2.5rpx solid var(--text-muted);
  border-right: 2.5rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-right: 4rpx;
  flex-shrink: 0;
}

/* ── Menu Section ── */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 4rpx;
}

.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  white-space: nowrap;
}

.section-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(28, 25, 23, 0.06) 0%,
    transparent 100%
  );
}

/* ── Menu Card ── */
.menu-card {
  background: var(--bg-elevated);
  border-radius: 24rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  transition: background-color var(--duration-fast) ease;
  position: relative;
}

.menu-item:not(:last-child)::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 28rpx;
  right: 28rpx;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    rgba(28, 25, 23, 0.04) 0%,
    rgba(28, 25, 23, 0.08) 50%,
    rgba(28, 25, 23, 0.04) 100%
  );
}

.menu-item:active {
  background: rgba(28, 25, 23, 0.03);
}

.menu-item-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
  line-height: 1.3;
}

.menu-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.4;
}

.menu-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2.5rpx solid var(--text-muted);
  border-right: 2.5rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-right: 4rpx;
  flex-shrink: 0;
}

.menu-extra {
  font-size: 26rpx;
  color: var(--text-muted);
  font-weight: 500;
  margin-right: 8rpx;
  flex-shrink: 0;
}

/* ── Switch Item ── */
.menu-item-switch {
  padding: 24rpx 28rpx;
}

.menu-item-switch .menu-item-content {
  padding-right: 20rpx;
}

.menu-switch {
  transform: scale(0.85);
  transform-origin: right center;
  flex-shrink: 0;
}

/* ── Version Footer ── */
.version-footer {
  display: flex;
  justify-content: center;
  padding: 24rpx 0 8rpx;
}

.version-text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  opacity: 0.6;
}
