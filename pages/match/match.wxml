<view class="page">
  <view class="ambient-bg">
    <view class="mesh-orb mesh-orb-3" style="top: 40%; left: -10%;"></view>
  </view>

  <view class="page-header-bar">
    <view class="header-left" bindtap="goToUserHome" data-author="{{myName}}">
      <image class="header-avatar" src="{{userAvatar}}" mode="aspectFill"/>
    </view>
    <text class="header-title">匹配</text>
    <view class="header-action">
      <view class="notification-dot"></view>
    </view>
  </view>

  <view class="content">
    <view class="content-inner">

      <!-- 匹配关闭状态 -->
      <view wx:if="{{!isMatchOpen}}" class="closed-state anim-fade-in">
        <view class="closed-icon">
          <view class="clock-ring"></view>
          <view class="clock-hand-hour"></view>
          <view class="clock-hand-minute"></view>
        </view>
        <text class="closed-title">匹配尚未开启</text>
        <text class="closed-desc">每周二开放一次匹配机会</text>
        <view class="countdown-card">
          <text class="countdown-label">距离下次开启</text>
          <text class="countdown-value">{{countdownText}}</text>
        </view>
      </view>

      <!-- 未匹配：入口页 -->
      <view wx:elif="{{!isMatched}}" class="entry-state anim-fade-in">
        <view class="entry-content">
          <view class="entry-icon">
            <view class="blind-box-icon"></view>
          </view>
          <text class="entry-title">周二盲盒</text>
          <text class="entry-subtitle">每周一次，打开一个未知灵魂</text>
          <view class="entry-btn-wrapper">
            <view class="btn-match" bindtap="doMatch">
              <text>匹配</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 已匹配：结果页 -->
      <view wx:else class="matched-result">
        <!-- Back to blind box -->
        <view class="result-back-btn" bindtap="resetMatch">
          <view class="result-back-arrow"></view>
          <text class="result-back-text">重新匹配</text>
        </view>

        <!-- Profile Card -->
        <view class="profile-card anim-scale-in">
          <image class="profile-avatar" src="{{matchAvatar}}" mode="aspectFill" bindtap="goToUserHome" data-author="{{matchName}}"/>
          <view class="profile-info">
            <text class="profile-name">{{matchName}}</text>
            <text class="profile-bio">{{matchBio}}</text>
            <view class="tag-list">
              <view class="tag" wx:for="{{tags}}" wx:key="index">{{item}}</view>
            </view>
          </view>
        </view>

        <!-- Compatibility -->
        <view class="compatibility-section anim-fade-in-up" style="animation-delay: 0.15s">
          <view class="compatibility-header">
            <text class="section-label">契合度</text>
            <text class="compatibility-score">{{compatibility}}%</text>
          </view>
          <view class="compatibility-bar">
            <view class="compatibility-fill" style="width: {{compatibility}}%;"></view>
          </view>
          <text class="compatibility-desc">你们在生活节奏和价值观上高度同频</text>
        </view>

        <!-- Why Matched -->
        <view class="insight-section anim-fade-in-up" style="animation-delay: 0.25s">
          <text class="section-label">为什么匹配</text>
          <view class="insight-card">
            <text class="quote-mark">"</text>
            <text class="insight-text">{{matchInsight}}</text>
          </view>
        </view>

        <!-- Icebreakers -->
        <view class="icebreaker-section anim-fade-in-up" style="animation-delay: 0.35s">
          <text class="section-label">试试这样开场</text>
          <view class="icebreaker-list">
            <view class="icebreaker-item" wx:for="{{icebreakers}}" wx:key="index" bindtap="copyIcebreaker" data-text="{{item}}">
              <text class="icebreaker-text">{{item}}</text>
              <view class="copy-btn">复制</view>
            </view>
          </view>
        </view>

        <view class="bottom-spacer"></view>
      </view>
    </view>
  </view>

  <!-- Match Animation Overlay -->
  <view class="match-animation-overlay {{isMatching ? 'overlay-visible' : ''}}">
    <view class="animation-dim"></view>

    <!-- 光芒爆发 -->
    <view class="light-burst {{matchPhase === 'glow' || matchPhase === 'reveal' ? 'light-burst-active' : ''}}">
      <view class="light-ray-wrap" wx:for="{{12}}" wx:key="index" style="transform: rotate({{index * 30}}deg)">
        <view class="light-ray-bar" style="animation-delay: {{index * 0.03}}s"></view>
      </view>
    </view>

    <!-- 中心舞台 -->
    <view class="animation-center">
      <!-- 摇晃盲盒 -->
      <view class="shake-box {{matchPhase === 'shake' ? 'shake-box-active' : 'shake-box-hidden'}}">
        <view class="shake-box-inner">
          <text class="shake-box-q">?</text>
        </view>
      </view>

      <!-- 翻转卡片 -->
      <view class="flip-wrap {{matchPhase !== 'shake' ? 'flip-wrap-visible' : ''}}">
        <view class="flip-card {{matchPhase === 'reveal' ? 'flip-card-flipped' : ''}}">
          <view class="flip-side flip-side-front">
            <view class="shake-box-inner">
              <text class="shake-box-q">?</text>
            </view>
          </view>
          <view class="flip-side flip-side-back">
            <image class="reveal-avatar" src="{{matchAvatar}}" mode="aspectFill"/>
            <view class="reveal-ring"></view>
          </view>
        </view>
      </view>

      <!-- 揭示信息 -->
      <view class="reveal-meta {{matchPhase === 'reveal' ? 'reveal-meta-visible' : ''}}">
        <text class="reveal-meta-name">{{matchName}}</text>
        <text class="reveal-meta-score">契合度 {{compatibility}}%</text>
      </view>
    </view>
  </view>
</view>
