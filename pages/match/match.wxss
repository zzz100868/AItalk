.page {
  min-height: 100vh;
  background: #faf9f7;
  position: relative;
  color: #1c1917;
}

/* ── Cinematic Background ── */
.ambient-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(120rpx);
  will-change: transform;
}

.orb-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.1) 0%, transparent 60%);
  top: -20%;
  left: -20%;
  animation: meshFloat1 18s ease-in-out infinite;
}

.orb-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.08) 0%, transparent 60%);
  bottom: 10%;
  right: -25%;
  animation: meshFloat2 22s ease-in-out infinite;
}

.orb-3 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(140, 120, 180, 0.05) 0%, transparent 60%);
  top: 40%;
  left: 30%;
  animation: meshFloat3 25s ease-in-out infinite;
}

.noise-layer {
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 256rpx 256rpx;
}

/* ── Header (dark mode) ── */
.dark-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
}

.dark-header .header-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 2rpx solid rgba(28, 25, 23, 0.1);
}

.dark-header .header-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #57534e;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 0 40rpx 340rpx;
  display: flex;
  flex-direction: column;
}

/* ═══════════════════════════════════════
   CLOSED STATE — Cinematic Timer
   ═══════════════════════════════════════ */
.closed-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  position: fixed;
  inset: 0;
  z-index: 2;
  padding: 60rpx;
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
}

.closed-visual {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.closed-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(196, 113, 90, 0.15);
}

.closed-ring-inner {
  position: absolute;
  inset: 24rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(196, 113, 90, 0.08);
  animation: subtleRotate 30s linear infinite;
}

.closed-ring-dot {
  position: absolute;
  top: -4rpx;
  left: 50%;
  margin-left: -4rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 16rpx var(--accent-glow);
}

.closed-emoji {
  font-size: 64rpx;
  line-height: 1;
}

.closed-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.closed-title {
  font-size: 48rpx;
  font-weight: 300;
  color: #1c1917;
  letter-spacing: 0.06em;
}

.closed-desc {
  font-size: 26rpx;
  color: #57534e;
  text-align: center;
  line-height: 1.6;
  letter-spacing: 0.02em;
}

.countdown-display {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.countdown-label {
  font-size: 20rpx;
  color: #78716c;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 500;
}

.countdown-value {
  font-size: 72rpx;
  font-weight: 200;
  color: #1c1917;
  letter-spacing: 0.08em;
  font-variant-numeric: tabular-nums;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* ═══════════════════════════════════════
   ENTRY STATE — Full-screen Blind Box
   ═══════════════════════════════════════ */
.entry-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: fixed;
  inset: 0;
  z-index: 2;
  padding: 60rpx;
}

.entry-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 60rpx;
}

.box-stage {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.box-glow {
  position: absolute;
  inset: -60rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.12) 0%, transparent 65%);
  animation: glowPulse 4s ease-in-out infinite;
}

.box-shape {
  width: 200rpx;
  height: 200rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #c4715a 0%, #d4a574 50%, #c4715a 100%);
  background-size: 200% 200%;
  animation: gradientShift 6s ease-in-out infinite, floatSlow 8s ease-in-out infinite;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 20rpx 60rpx rgba(196, 113, 90, 0.25),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.3),
    inset 0 -2rpx 0 rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

@keyframes gradientShift {
  0%, 100% { background-position: 0% 0%; }
  50% { background-position: 100% 100%; }
}

.box-q {
  font-size: 100rpx;
  font-weight: 200;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
}

.box-orbit {
  position: absolute;
  inset: -20rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(196, 113, 90, 0.12);
  animation: subtleRotate 20s linear infinite;
}

.box-orbit-dot {
  position: absolute;
  top: -3rpx;
  left: 50%;
  margin-left: -3rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(196, 113, 90, 0.5);
}

.entry-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.entry-title {
  font-size: 72rpx;
  font-weight: 200;
  color: #1c1917;
  letter-spacing: 0.12em;
}

.entry-subtitle {
  font-size: 26rpx;
  color: #57534e;
  text-align: center;
  letter-spacing: 0.06em;
  line-height: 1.6;
}

.entry-cta {
  margin-top: 20rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.btn-match {
  width: 420rpx;
  background: linear-gradient(135deg, #c4715a, #d4a574);
  color: #fff;
  border: none;
  border-radius: 9999rpx;
  padding: 36rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: all 0.4s var(--ease-out-expo);
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(196, 113, 90, 0.25);
}

.btn-match::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(196, 113, 90, 0.2), rgba(212, 165, 116, 0.15));
  opacity: 0;
  transition: opacity 0.4s ease;
}

.btn-match::after { border: none; }

.btn-match:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(196, 113, 90, 0.35);
}

.btn-match:active::before {
  opacity: 1;
}

/* ═══════════════════════════════════════
   RESULT STATE — Editorial Magazine
   ═══════════════════════════════════════ */
.matched-result {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-top: 20rpx;
}

.result-back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  align-self: flex-start;
  margin-bottom: 40rpx;
}

.result-back-arrow {
  width: 14rpx;
  height: 14rpx;
  border-left: 2rpx solid #78716c;
  border-bottom: 2rpx solid #78716c;
  transform: rotate(45deg);
}

.result-back-text {
  font-size: 24rpx;
  color: #78716c;
  font-weight: 400;
  letter-spacing: 0.04em;
}

/* ── Hero Profile Section ── */
.result-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.hero-avatar-wrap {
  position: relative;
  margin-bottom: 36rpx;
}

.hero-avatar {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 3rpx solid rgba(28, 25, 23, 0.06);
  box-shadow: 0 24rpx 80rpx rgba(196, 113, 90, 0.12);
}

.hero-avatar-ring {
  position: absolute;
  inset: -12rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(196, 113, 90, 0.2);
  animation: ringPulse 4s ease-in-out infinite;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.03); opacity: 0.8; }
}

.hero-name {
  font-size: 64rpx;
  font-weight: 300;
  color: #1c1917;
  letter-spacing: 0.08em;
  margin-bottom: 12rpx;
}

.hero-bio {
  font-size: 26rpx;
  color: #57534e;
  text-align: center;
  line-height: 1.6;
  max-width: 500rpx;
  letter-spacing: 0.02em;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

.hero-tag {
  padding: 10rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: #44403c;
  border: 1rpx solid rgba(28, 25, 23, 0.08);
  background: rgba(255, 255, 255, 0.9);
  letter-spacing: 0.02em;
  box-shadow: 0 2rpx 8rpx rgba(196, 113, 90, 0.04);
}

/* ── Score Display ── */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  margin-bottom: 48rpx;
  position: relative;
}

.score-section::before,
.score-section::after {
  content: '';
  position: absolute;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(28, 25, 23, 0.06), transparent);
}

.score-section::before { top: 0; }
.score-section::after { bottom: 0; }

.score-label {
  font-size: 20rpx;
  color: #78716c;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.score-number {
  font-size: 120rpx;
  font-weight: 200;
  line-height: 1;
  letter-spacing: -0.04em;
  background: linear-gradient(135deg, #c4715a, #d4a574, #c4715a);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.score-unit {
  font-size: 40rpx;
  font-weight: 300;
}

.score-bar {
  width: 240rpx;
  height: 3rpx;
  background: rgba(28, 25, 23, 0.06);
  border-radius: 2rpx;
  margin-top: 24rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #c4715a, #d4a574);
  border-radius: 2rpx;
  animation: progressFill 1.5s var(--ease-out-expo) both;
}

.score-desc {
  font-size: 24rpx;
  color: #57534e;
  margin-top: 20rpx;
  letter-spacing: 0.02em;
}

/* ── Insight Block ── */
.insight-block {
  margin-bottom: 56rpx;
  position: relative;
  padding-left: 32rpx;
}

.insight-block::before {
  content: '';
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 4rpx;
  width: 2rpx;
  background: linear-gradient(180deg, rgba(196, 113, 90, 0.5), rgba(196, 113, 90, 0.05));
}

.insight-label {
  font-size: 20rpx;
  color: #78716c;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.insight-quote {
  font-size: 30rpx;
  line-height: 2;
  color: #44403c;
  font-weight: 400;
  letter-spacing: 0.02em;
}

/* ── Icebreakers ── */
.icebreaker-block {
  margin-bottom: 80rpx;
}

.icebreaker-label {
  font-size: 20rpx;
  color: #78716c;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 28rpx;
}

.icebreaker-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.icebreaker-item {
  padding: 28rpx 0;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  border-bottom: 1rpx solid rgba(28, 25, 23, 0.04);
  transition: all 0.3s var(--ease-out-expo);
}

.icebreaker-item:active {
  opacity: 0.7;
  transform: translateX(8rpx);
}

.icebreaker-item:last-child {
  border-bottom: none;
}

.icebreaker-num {
  font-size: 20rpx;
  color: rgba(196, 113, 90, 0.5);
  font-weight: 600;
  font-variant-numeric: tabular-nums;
  min-width: 36rpx;
  padding-top: 6rpx;
}

.icebreaker-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.8;
  color: #44403c;
  font-weight: 400;
}

.copy-btn {
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  font-weight: 500;
  color: rgba(196, 113, 90, 0.7);
  border: 1rpx solid rgba(196, 113, 90, 0.2);
  background: rgba(196, 113, 90, 0.06);
  flex-shrink: 0;
  margin-top: 4rpx;
  transition: all 0.2s ease;
}

.copy-btn:active {
  background: rgba(196, 113, 90, 0.15);
  border-color: rgba(196, 113, 90, 0.4);
}

.bottom-spacer {
  height: 40rpx;
}

/* ── Start Chat Button ── */
.start-chat-bar {
  position: fixed;
  bottom: calc(88rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 50;
  background: rgba(250, 249, 247, 0.92);
  backdrop-filter: saturate(200%) blur(40rpx);
  -webkit-backdrop-filter: saturate(200%) blur(40rpx);
  border-top: 1rpx solid rgba(28, 25, 23, 0.04);
  padding: 20rpx 48rpx calc(12rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.start-chat-btn {
  width: 100%;
  background: linear-gradient(135deg, #c4715a, #d4a574);
  color: #fff;
  border-radius: 9999rpx;
  padding: 32rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(196, 113, 90, 0.25);
  transition: all 0.3s var(--ease-out-expo);
}

.start-chat-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(196, 113, 90, 0.35);
}

/* ── Pay Modal ── */
.pay-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(28, 25, 23, 0.5);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  animation: fadeIn 0.25s ease both;
}

.pay-modal-dialog {
  background: #faf9f7;
  border-radius: 28rpx;
  padding: 40rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
  width: 100%;
  max-width: 600rpx;
  position: relative;
  animation: modalSlideUp 0.4s var(--ease-out-expo) both;
}

@keyframes modalSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.pay-modal-close {
  position: absolute;
  top: 24rpx;
  right: 32rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-close-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.pay-close-icon::before,
.pay-close-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 2rpx;
  background: #78716c;
  border-radius: 1rpx;
}

.pay-close-icon::before { transform: translate(-50%, -50%) rotate(45deg); }
.pay-close-icon::after { transform: translate(-50%, -50%) rotate(-45deg); }

.pay-modal-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 48rpx;
  margin-top: 16rpx;
}

.pay-modal-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1c1917;
  letter-spacing: 0.04em;
}

.pay-modal-subtitle {
  font-size: 26rpx;
  color: #78716c;
}

.pay-modal-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
  margin-bottom: 48rpx;
}

.pay-price-tag {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.pay-currency {
  font-size: 40rpx;
  font-weight: 400;
  color: #c4715a;
}

.pay-price {
  font-size: 96rpx;
  font-weight: 300;
  color: #1c1917;
  line-height: 1;
  letter-spacing: -0.02em;
}

.pay-benefits {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pay-benefit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #44403c;
  padding: 0 24rpx;
}

.pay-check {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(127, 176, 105, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
}

.pay-check::after {
  content: '';
  width: 8rpx;
  height: 14rpx;
  border-right: 2rpx solid rgba(127, 176, 105, 0.8);
  border-bottom: 2rpx solid rgba(127, 176, 105, 0.8);
  transform: rotate(45deg) translate(-1rpx, -2rpx);
}

.pay-modal-footer {
  width: 100%;
}

.pay-btn {
  width: 100%;
  background: linear-gradient(135deg, #c4715a, #d4a574);
  color: #fff;
  border-radius: 9999rpx;
  padding: 32rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(196, 113, 90, 0.25);
  transition: all 0.3s var(--ease-out-expo);
}

.pay-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(196, 113, 90, 0.35);
}

/* ═══════════════════════════════════════
   MATCH ANIMATION — Cinematic Overlay
   ═══════════════════════════════════════ */
.match-animation-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}

.overlay-visible {
  opacity: 1;
  pointer-events: auto;
}

.animation-dim {
  position: absolute;
  inset: 0;
  background: rgba(250, 249, 247, 0);
  animation: dimIn 0.5s var(--ease-smooth) forwards;
}

@keyframes dimIn {
  to { background: rgba(250, 249, 247, 0.94); }
}

/* Light Burst */
.light-burst {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  z-index: 2;
}

.light-ray-wrap {
  position: absolute;
  width: 0;
  height: 0;
  transform-origin: center center;
}

.light-ray-bar {
  position: absolute;
  width: 2rpx;
  height: 350rpx;
  background: linear-gradient(to top, transparent 0%, rgba(196, 113, 90, 0.3) 30%, rgba(212, 165, 116, 0.45) 55%, transparent 100%);
  left: -1rpx;
  top: -370rpx;
  opacity: 0;
  transform: scaleY(0);
  transform-origin: bottom center;
  will-change: transform, opacity;
}

.light-burst-active .light-ray-bar {
  animation: rayShoot 1.2s var(--ease-out-expo) forwards;
}

@keyframes rayShoot {
  0% { opacity: 0; transform: scaleY(0); }
  25% { opacity: 0.8; }
  50% { opacity: 0.5; transform: scaleY(1.2); }
  100% { opacity: 0; transform: scaleY(1.8); }
}

/* Particle Burst */
.particle-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  z-index: 2;
}

.particle {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: rgba(196, 113, 90, 0.6);
  opacity: 0;
}

.particle-active .particle {
  animation: particleBurst 1.4s var(--ease-out-expo) forwards;
}

@keyframes particleBurst {
  0% { opacity: 0; transform: translate(0, 0) scale(1); }
  20% { opacity: 1; }
  100% { opacity: 0; transform: var(--particle-end) scale(0); }
}

/* Center Stage */
.animation-center {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

/* Shake Box */
.shake-box {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s ease;
  will-change: transform, opacity;
}

.shake-box-hidden { opacity: 0; }

.shake-box-active {
  animation: boxShake 1s ease-in-out;
}

@keyframes boxShake {
  0%, 100% { transform: rotate(0deg) scale(1); }
  8% { transform: rotate(-12deg) scale(1.05); }
  16% { transform: rotate(12deg) scale(1.05); }
  24% { transform: rotate(-10deg) scale(1.04); }
  32% { transform: rotate(10deg) scale(1.04); }
  40% { transform: rotate(-7deg) scale(1.03); }
  48% { transform: rotate(7deg) scale(1.03); }
  56% { transform: rotate(-4deg) scale(1.02); }
  64% { transform: rotate(4deg) scale(1.01); }
  75% { transform: rotate(-2deg) scale(1); }
  85% { transform: rotate(1deg) scale(1); }
}

.shake-box-inner {
  width: 200rpx;
  height: 200rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #c4715a, #d4a574);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 24rpx 80rpx rgba(196, 113, 90, 0.3),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.25);
}

.shake-box-q {
  font-size: 110rpx;
  font-weight: 200;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1;
}

/* Flip Card */
.flip-wrap {
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.flip-wrap-visible { opacity: 1; }

.flip-card {
  width: 100%;
  height: 100%;
  position: relative;
  transition: transform 1.2s cubic-bezier(0.23, 1.15, 0.46, 1);
  transform-style: preserve-3d;
  will-change: transform;
}

.flip-card-flipped { transform: rotateY(180deg); }

.flip-side {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  overflow: hidden;
}

.flip-side-front {
  background: linear-gradient(135deg, #c4715a, #d4a574);
  box-shadow: 0 24rpx 80rpx rgba(196, 113, 90, 0.3);
}

.flip-side-back {
  transform: rotateY(180deg);
  border: 3rpx solid rgba(28, 25, 23, 0.06);
  box-shadow: 0 12rpx 48rpx rgba(196, 113, 90, 0.1);
}

.reveal-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.reveal-ring {
  position: absolute;
  inset: -14rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(196, 113, 90, 0.3);
  opacity: 0;
  transform: scale(0.85);
  transition: all 0.8s var(--ease-spring) 0.3s;
  box-shadow: 0 0 60rpx rgba(196, 113, 90, 0.15);
  pointer-events: none;
}

.flip-card-flipped .reveal-ring {
  opacity: 1;
  transform: scale(1);
  animation: glowPulse 3s ease-in-out infinite 1.2s;
}

/* Reveal Meta */
.reveal-meta {
  position: absolute;
  top: 310rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  opacity: 0;
  transform: translateY(30rpx);
  transition: all 0.7s var(--ease-out-expo) 0.4s;
  z-index: 4;
}

.reveal-meta-visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-meta-name {
  font-size: 52rpx;
  font-weight: 300;
  color: #1c1917;
  letter-spacing: 0.08em;
}

.reveal-meta-score {
  font-size: 24rpx;
  color: #78716c;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

/* ── Animations ── */
.anim-scale-in {
  animation: scaleIn 0.6s var(--ease-out-expo) both;
}

.anim-fade-in-up {
  animation: fadeInUp 0.7s var(--ease-out-expo) both;
}

@keyframes scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes fadeInUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
