.page {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
}

/* ── Ambient Background ── */
.ambient-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  background: radial-gradient(ellipse at 50% -10%, rgba(196, 113, 90, 0.05) 0%, transparent 55%);
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 32rpx 32rpx 340rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ── Match Closed State ── */
.closed-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  gap: 32rpx;
  padding: 40rpx;
}

.closed-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 9999rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.clock-ring {
  width: 72rpx;
  height: 72rpx;
  border-radius: 9999rpx;
  border: 4rpx solid var(--border-medium);
  position: relative;
}

.clock-hand-hour {
  position: absolute;
  width: 4rpx;
  height: 20rpx;
  background: var(--text-muted);
  border-radius: 9999rpx;
  top: 50%;
  left: 50%;
  margin-left: -2rpx;
  margin-top: -20rpx;
  transform-origin: bottom center;
  transform: rotate(45deg);
}

.clock-hand-minute {
  position: absolute;
  width: 3rpx;
  height: 28rpx;
  background: var(--text-muted);
  border-radius: 9999rpx;
  top: 50%;
  left: 50%;
  margin-left: -1.5rpx;
  margin-top: -28rpx;
  transform-origin: bottom center;
  transform: rotate(120deg);
}

.closed-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.closed-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

.countdown-card {
  margin-top: 16rpx;
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 40rpx 48rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  max-width: 480rpx;
}

.countdown-label {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-weight: 500;
}

.countdown-value {
  font-size: 52rpx;
  font-weight: 300;
  color: var(--accent);
  letter-spacing: 0.04em;
  font-variant-numeric: tabular-nums;
}

.bottom-spacer {
  height: 20rpx;
}

/* ── Entry State ── */
.entry-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 70vh;
  padding: 40rpx;
}

.entry-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.entry-icon {
  margin-bottom: 8rpx;
}

.blind-box-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent-warm));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx -8rpx var(--accent-glow);
  position: relative;
}

.blind-box-icon::before {
  content: '?';
  font-size: 88rpx;
  font-weight: 200;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1;
}

.entry-title {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 0.04em;
}

.entry-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  letter-spacing: 0.02em;
}

.entry-btn-wrapper {
  margin-top: 24rpx;
  width: 100%;
  display: flex;
  justify-content: center;
}

.btn-match {
  width: 100%;
  max-width: 400rpx;
  background: var(--text-primary);
  color: var(--bg-base);
  border-radius: 9999rpx;
  padding: 32rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: transform var(--duration-fast) var(--ease-spring),
              opacity var(--duration-fast) var(--ease-smooth);
}

.btn-match::after { border: none; }

.btn-match:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.matched-result {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* ── Profile Card ── */
.profile-card {
  background: var(--bg-elevated);
  border-radius: 32rpx;
  padding: 40rpx 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  border: 1rpx solid var(--border-subtle);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.profile-avatar {
  width: 220rpx;
  height: 220rpx;
  border-radius: 28rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.profile-bio {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-top: 6rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
}

/* ── Compatibility ── */
.compatibility-section {
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.compatibility-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.compatibility-score {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -0.02em;
}

.compatibility-bar {
  width: 100%;
  height: 8rpx;
  background: var(--bg-surface);
  border-radius: 4rpx;
  overflow: hidden;
}

.compatibility-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4rpx;
}

.compatibility-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ── Insight ── */
.insight-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-card {
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  border: 1rpx solid var(--border-subtle);
  position: relative;
}

.quote-mark {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--accent);
  opacity: 0.12;
  line-height: 1;
  position: absolute;
  top: 16rpx;
  left: 24rpx;
}

.insight-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary);
  position: relative;
  z-index: 1;
}

/* ── Icebreakers ── */
.icebreaker-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.icebreaker-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.icebreaker-item {
  background: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid var(--border-subtle);
  transition: all 0.2s ease;
}

.icebreaker-item:active {
  background: var(--bg-surface);
  transform: scale(0.99);
}

.icebreaker-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.copy-btn {
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--accent);
  background: rgba(196, 113, 90, 0.08);
  flex-shrink: 0;
}

/* ── Floating Button ── */
.floating-action-bar {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 50;
  padding: 16rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  background: linear-gradient(to top, var(--bg-base) 0%, rgba(250, 249, 247, 0.9) 60%, transparent 100%);
  pointer-events: none;
}

.btn-start-chat {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: var(--accent);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s ease;
  padding: 0;
  margin: 0;
}

.btn-start-chat::after {
  border: none;
}

.btn-start-chat:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ── Animations ── */
@keyframes scaleIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes fadeInUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.anim-scale-in {
  animation: scaleIn 0.5s var(--ease-out-expo) both;
}

.anim-fade-in-up {
  animation: fadeInUp 0.5s var(--ease-out-expo) both;
}

/* ── Chat Dialog Overlay ── */
.chat-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99999;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  transition: opacity 0.25s ease;
}

.chat-dialog {
  position: absolute;
  left: 0;
  right: 0;
  height: 85vh;
  background: var(--bg-base);
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-top: 1rpx solid var(--border-subtle);
  transition: bottom 0.35s var(--ease-out-expo);
}

.anim-fade-in {
  animation: fadeIn 0.25s ease both;
}



/* Chat Header */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
  border-bottom: 1rpx solid var(--border-subtle);
  background: var(--bg-base);
  flex-shrink: 0;
}

.chat-header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-back-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid var(--text-primary);
  border-left: 2rpx solid var(--text-primary);
  transform: rotate(-45deg);
}

.chat-header-center {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-header-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.chat-header-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.chat-header-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.chat-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--success);
}

/* Chat Messages */
.chat-messages-wrap {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.chat-messages-inner {
  height: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.chat-welcome {
  text-align: center;
  margin-bottom: 20rpx;
}

.chat-welcome-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

.chat-msg {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.chat-msg-user {
  justify-content: flex-end;
}

.chat-msg-match {
  justify-content: flex-start;
}

.chat-msg-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  margin-bottom: 4rpx;
}

.chat-msg-bubble {
  max-width: 72%;
  padding: 16rpx 20rpx;
}

.chat-msg-bubble-user {
  background: var(--accent);
  color: #ffffff;
  border-radius: 18rpx 18rpx 4rpx 18rpx;
}

.chat-msg-bubble-match {
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-subtle);
  border-radius: 4rpx 18rpx 18rpx 18rpx;
}

.chat-msg-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: inherit;
}

.chat-msg-bubble-match .chat-msg-text {
  color: var(--text-secondary);
}

/* Chat Input */
.chat-input-area {
  padding: 16rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-subtle);
  background: var(--bg-base);
  flex-shrink: 0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.chat-input-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-elevated);
  border-radius: 9999rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  border: 2rpx solid var(--border-medium);
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.chat-input {
  flex: 1;
  min-width: 200rpx;
  width: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 10rpx 0;
  background: transparent;
  height: 48rpx;
  line-height: 48rpx;
  display: block;
}

.chat-placeholder {
  color: var(--text-muted);
}

.chat-send-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.chat-send-active {
  background: var(--accent);
}

.send-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid var(--text-muted);
  border-right: 2rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-left: -2rpx;
}

.chat-send-active .send-arrow {
  border-color: #ffffff;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
/* ── Match Animation Overlay ── */
.match-animation-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s ease;
}

.overlay-visible {
  opacity: 1;
  pointer-events: auto;
}

.animation-dim {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0);
  animation: dimIn 0.4s ease forwards;
}

@keyframes dimIn {
  to {
    background: rgba(0, 0, 0, 0.55);
  }
}

/* ── Light Burst ── */
.light-burst {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  z-index: 2;
}

.light-ray-wrap {
  position: absolute;
  width: 0;
  height: 0;
  transform-origin: center center;
}

.light-ray-bar {
  position: absolute;
  width: 4rpx;
  height: 220rpx;
  background: linear-gradient(to top, transparent 0%, var(--accent) 40%, transparent 100%);
  left: -2rpx;
  top: -240rpx;
  opacity: 0;
  transform: scaleY(0);
  transform-origin: bottom center;
}

.light-burst-active .light-ray-bar {
  animation: rayShoot 0.7s ease-out forwards;
}

@keyframes rayShoot {
  0% {
    opacity: 0;
    transform: scaleY(0);
  }
  40% {
    opacity: 0.85;
  }
  100% {
    opacity: 0;
    transform: scaleY(1.3);
  }
}

/* ── Animation Center Stage ── */
.animation-center {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 3;
}

/* ── Shake Box ── */
.shake-box {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s ease;
}

.shake-box-hidden {
  opacity: 0;
}

.shake-box-active {
  animation: boxShake 0.9s ease-in-out;
}

@keyframes boxShake {
  0%, 100% {
    transform: rotate(0deg) scale(1);
  }
  10% {
    transform: rotate(-10deg) scale(1.03);
  }
  20% {
    transform: rotate(10deg) scale(1.03);
  }
  30% {
    transform: rotate(-8deg) scale(1.03);
  }
  40% {
    transform: rotate(8deg) scale(1.03);
  }
  50% {
    transform: rotate(-5deg) scale(1.02);
  }
  60% {
    transform: rotate(5deg) scale(1.02);
  }
  70% {
    transform: rotate(-3deg) scale(1.01);
  }
  80% {
    transform: rotate(3deg) scale(1.01);
  }
  90% {
    transform: rotate(0deg) scale(1);
  }
}

.shake-box-inner {
  width: 200rpx;
  height: 200rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, var(--accent), var(--accent-warm));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx -8rpx var(--accent-glow);
  position: relative;
}

.shake-box-q {
  font-size: 110rpx;
  font-weight: 200;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1;
}

/* ── Flip Card ── */
.flip-wrap {
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.flip-wrap-visible {
  opacity: 1;
}

.flip-card {
  width: 100%;
  height: 100%;
  position: relative;
  transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform-style: preserve-3d;
}

.flip-card-flipped {
  transform: rotateY(180deg);
}

.flip-side {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 36rpx;
  overflow: hidden;
}

.flip-side-front {
  background: linear-gradient(135deg, var(--accent), var(--accent-warm));
  box-shadow: 0 16rpx 48rpx -8rpx var(--accent-glow);
}

.flip-side-back {
  transform: rotateY(180deg);
}

.reveal-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.reveal-ring {
  position: absolute;
  inset: -10rpx;
  border-radius: 46rpx;
  border: 4rpx solid var(--accent);
  opacity: 0;
  transform: scale(0.85);
  transition: all 0.5s ease 0.35s;
  box-shadow: 0 0 40rpx var(--accent-glow);
  pointer-events: none;
}

.flip-card-flipped .reveal-ring {
  opacity: 1;
  transform: scale(1);
}

/* ── Reveal Meta ── */
.reveal-meta {
  position: absolute;
  top: 280rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.5s ease 0.2s;
  z-index: 4;
}

.reveal-meta-visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal-meta-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.4);
  letter-spacing: 0.02em;
}

.reveal-meta-score {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 1rpx 10rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 0.04em;
}
