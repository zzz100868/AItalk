.page {
  min-height: 100vh;
  background: var(--bg-base);
  position: relative;
}

/* ── Ambient Background ── */
.ambient-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background: radial-gradient(ellipse at 50% -10%, rgba(196, 113, 90, 0.05) 0%, transparent 55%);
}

/* ── Content ── */
.content {
  padding-top: calc(110rpx + max(48rpx, env(safe-area-inset-top)));
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.content-inner {
  padding: 32rpx 32rpx 340rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.bottom-spacer {
  height: 20rpx;
}

/* ── Profile Card ── */
.profile-card {
  background: var(--bg-elevated);
  border-radius: 32rpx;
  padding: 40rpx 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  border: 1rpx solid var(--border-subtle);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.profile-avatar {
  width: 220rpx;
  height: 220rpx;
  border-radius: 28rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.profile-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
}

.profile-bio {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-top: 6rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
}

/* ── Compatibility ── */
.compatibility-section {
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 32rpx;
  border: 1rpx solid var(--border-subtle);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.compatibility-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.section-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.compatibility-score {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: -0.02em;
}

.compatibility-bar {
  width: 100%;
  height: 8rpx;
  background: var(--bg-surface);
  border-radius: 4rpx;
  overflow: hidden;
}

.compatibility-fill {
  height: 100%;
  background: var(--accent);
  border-radius: 4rpx;
}

.compatibility-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* ── Insight ── */
.insight-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-card {
  background: var(--bg-elevated);
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  border: 1rpx solid var(--border-subtle);
  position: relative;
}

.quote-mark {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--accent);
  opacity: 0.12;
  line-height: 1;
  position: absolute;
  top: 16rpx;
  left: 24rpx;
}

.insight-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary);
  position: relative;
  z-index: 1;
}

/* ── Icebreakers ── */
.icebreaker-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.icebreaker-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.icebreaker-item {
  background: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 1rpx solid var(--border-subtle);
  transition: all 0.2s ease;
}

.icebreaker-item:active {
  background: var(--bg-surface);
  transform: scale(0.99);
}

.icebreaker-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.copy-btn {
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--accent);
  background: rgba(196, 113, 90, 0.08);
  flex-shrink: 0;
}

/* ── Floating Button ── */
.floating-action-bar {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  z-index: 50;
  padding: 16rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
  background: linear-gradient(to top, var(--bg-base) 0%, rgba(250, 249, 247, 0.9) 60%, transparent 100%);
  pointer-events: none;
}

.btn-start-chat {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  height: 92rpx;
  border-radius: 46rpx;
  background: var(--accent);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s ease;
  padding: 0;
  margin: 0;
}

.btn-start-chat::after {
  border: none;
}

.btn-start-chat:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* ── Animations ── */
@keyframes scaleIn {
  from { transform: scale(0.95); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes fadeInUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.anim-scale-in {
  animation: scaleIn 0.5s var(--ease-out-expo) both;
}

.anim-fade-in-up {
  animation: fadeInUp 0.5s var(--ease-out-expo) both;
}

/* ── Chat Dialog Overlay ── */
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.anim-slide-up {
  animation: slideUp 0.35s var(--ease-out-expo) both;
}

.anim-fade-in {
  animation: fadeIn 0.25s ease both;
}

.chat-overlay {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(6rpx);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.chat-dialog {
  height: 85vh;
  background: var(--bg-base);
  border-radius: 28rpx 28rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-top: 1rpx solid var(--border-subtle);
}

/* Chat Header */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + max(48rpx, env(safe-area-inset-top)));
  border-bottom: 1rpx solid var(--border-subtle);
  background: var(--bg-base);
}

.chat-header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-back-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid var(--text-primary);
  border-left: 2rpx solid var(--text-primary);
  transform: rotate(-45deg);
}

.chat-header-center {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-header-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
}

.chat-header-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.chat-header-right {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.chat-status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--success);
}

/* Chat Messages */
.chat-messages {
  flex: 1;
  padding: 20rpx 24rpx;
}

.chat-welcome {
  text-align: center;
  margin-bottom: 20rpx;
}

.chat-welcome-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

.chat-msg {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.chat-msg-user {
  justify-content: flex-end;
}

.chat-msg-match {
  justify-content: flex-start;
}

.chat-msg-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  margin-bottom: 4rpx;
}

.chat-msg-bubble {
  max-width: 72%;
  padding: 16rpx 20rpx;
}

.chat-msg-bubble-user {
  background: var(--accent);
  color: #ffffff;
  border-radius: 18rpx 18rpx 4rpx 18rpx;
}

.chat-msg-bubble-match {
  background: var(--bg-elevated);
  border: 1rpx solid var(--border-subtle);
  border-radius: 4rpx 18rpx 18rpx 18rpx;
}

.chat-msg-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: inherit;
}

.chat-msg-bubble-match .chat-msg-text {
  color: var(--text-secondary);
}

/* Chat Input */
.chat-input-area {
  padding: 12rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--border-subtle);
  background: var(--bg-base);
}

.chat-input-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg-elevated);
  border-radius: 9999rpx;
  padding: 6rpx 6rpx 6rpx 20rpx;
  border: 1rpx solid var(--border-subtle);
}

.chat-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 10rpx 0;
  background: transparent;
}

.chat-placeholder {
  color: var(--text-muted);
}

.chat-send-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.chat-send-active {
  background: var(--accent);
}

.send-arrow {
  width: 10rpx;
  height: 10rpx;
  border-top: 2rpx solid var(--text-muted);
  border-right: 2rpx solid var(--text-muted);
  transform: rotate(45deg);
  margin-left: -2rpx;
}

.chat-send-active .send-arrow {
  border-color: #ffffff;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
