.page-container {
  min-height: 100vh;
  background: var(--bg-base);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

/* ── View Layer Switch ── */
.view-layer {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
}

.view-active {
  opacity: 1;
  pointer-events: auto;
  z-index: 2;
}

.view-inactive {
  opacity: 0;
  pointer-events: none;
  z-index: 1;
}

/* ── Ambient Background ── */
.ambient-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.ambient-orb {
  position: absolute;
  border-radius: 9999rpx;
  filter: blur(120rpx);
  opacity: 0.12;
}

.orb-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.1), transparent 70%);
  top: -10%;
  right: -20%;
}

.orb-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(212, 165, 116, 0.06), transparent 70%);
  bottom: 20%;
  left: -15%;
}

.ambient-noise {
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128rpx;
}

/* ── Main Content ── */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 160rpx 32rpx 40rpx;
  position: relative;
  z-index: 1;
}

.call-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
  width: 100%;
}

/* ═══════════════════════════════════════
   通话结束状态
   ═══════════════════════════════════════ */

.avatar-frame-static {
  width: 280rpx;
  height: 280rpx;
  border-radius: 9999rpx;
  overflow: hidden;
  position: relative;
  border: 2rpx solid var(--border-medium);
}

.avatar-offline-ring {
  position: absolute;
  inset: -12rpx;
  border-radius: 9999rpx;
  border: 1rpx solid var(--border-subtle);
}

.call-ended-caption {
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 4rpx;
}

.call-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
}

.call-duration {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.call-separator {
  color: var(--text-muted);
}

.call-date {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.action-area {
  width: 100%;
  margin-top: 8rpx;
  display: flex;
  justify-content: center;
}

.btn-primary {
  width: 100%;
  max-width: 400rpx;
  background: var(--text-primary);
  color: var(--bg-base);
  border-radius: 9999rpx;
  padding: 28rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.01em;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-sizing: border-box;
}

.btn-primary::after { border: none; }

/* Phone icon */
.icon-phone {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.icon-phone::before {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid var(--bg-base);
  border-radius: 9999rpx;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.icon-phone::after {
  content: '';
  position: absolute;
  width: 18rpx;
  height: 8rpx;
  border: 2rpx solid var(--bg-base);
  border-top: none;
  border-radius: 0 0 9rpx 9rpx;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
}

/* ═══════════════════════════════════════
   通话中状态
   ═══════════════════════════════════════ */

.avatar-zone {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-ring-outer {
  position: absolute;
  inset: -20rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.15);
  animation: ringPulse 3s ease-in-out infinite;
}

.avatar-ring-mid {
  position: absolute;
  inset: -8rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.08);
  animation: ringPulse 3s ease-in-out infinite 0.5s;
}

@keyframes ringPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.03); opacity: 1; }
}

.avatar-float {
  animation: float 6s ease-in-out infinite;
  width: 100%;
  height: 100%;
}

.avatar-frame {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  overflow: hidden;
  position: relative;
  border: 2rpx solid var(--border-medium);
}

.ai-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(1.05) saturate(0.9);
}

.avatar-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.08) 100%);
}

/* Voice Wave Animation */
.voice-wave-container {
  position: absolute;
  bottom: -32rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 6rpx;
  height: 24rpx;
}

.voice-bar {
  width: 4rpx;
  border-radius: 9999rpx;
  background: var(--accent);
  animation: voiceWave 1.2s ease-in-out infinite;
}

.voice-bar:nth-child(1) { height: 8rpx; }
.voice-bar:nth-child(2) { height: 16rpx; }
.voice-bar:nth-child(3) { height: 12rpx; }
.voice-bar:nth-child(4) { height: 20rpx; }
.voice-bar:nth-child(5) { height: 14rpx; }
.voice-bar:nth-child(6) { height: 18rpx; }
.voice-bar:nth-child(7) { height: 10rpx; }

@keyframes voiceWave {
  0%, 100% { transform: scaleY(0.6); opacity: 0.5; }
  50% { transform: scaleY(1); opacity: 1; }
}

/* ── Call Info ── */
.call-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  z-index: 10;
}

.ai-name {
  color: var(--text-primary);
}

.call-status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.call-status {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 9999rpx;
  background: var(--accent);
}

.status-dot-live {
  animation: breathe-dot 2s ease-in-out infinite;
}

/* ── Controls ── */
.controls {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 48rpx;
  margin-top: 24rpx;
  z-index: 10;
}

.control-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.control-main {
  margin: 0 8rpx;
}

.control-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 9999rpx;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-out-expo);
}

.control-btn:active {
  transform: scale(0.88);
  opacity: 0.8;
}

.control-btn-active {
  background: var(--accent-dim);
  border-color: rgba(196, 113, 90, 0.2);
}

.control-btn-end {
  width: 120rpx;
  height: 120rpx;
  background: var(--error);
  border-color: transparent;
  box-shadow: 0 8rpx 32rpx -4rpx rgba(196, 90, 90, 0.3);
}

.control-btn-end:active {
  box-shadow: 0 4rpx 16rpx -4rpx rgba(196, 90, 90, 0.2);
}

.control-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  transition: color var(--duration-fast) ease;
}

.control-label-end {
  color: var(--error);
}

/* ── CSS Icons ── */
.icon-mic {
  position: relative;
  width: 36rpx;
  height: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mic-body {
  width: 18rpx;
  height: 28rpx;
  border-radius: 9rpx;
  background: var(--text-secondary);
  transition: background var(--duration-fast) ease;
}

.control-btn-active .mic-body { background: var(--accent); }

.mic-base {
  width: 26rpx;
  height: 14rpx;
  border: 2rpx solid var(--text-secondary);
  border-top: none;
  border-radius: 0 0 13rpx 13rpx;
  margin-top: -2rpx;
  transition: border-color var(--duration-fast) ease;
}

.control-btn-active .mic-base { border-color: var(--accent); }

.mic-slash {
  position: absolute;
  width: 3rpx;
  height: 50rpx;
  background: var(--error);
  transform: rotate(45deg);
  top: -4rpx;
  border-radius: 2rpx;
}

.icon-speaker {
  position: relative;
  width: 40rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
}

.speaker-body {
  width: 14rpx;
  height: 18rpx;
  background: var(--text-secondary);
  border-radius: 2rpx 4rpx 4rpx 2rpx;
  transition: background var(--duration-fast) ease;
}

.control-btn-active .speaker-body { background: var(--accent); }

.speaker-wave {
  width: 10rpx;
  height: 22rpx;
  border: 2rpx solid var(--text-secondary);
  border-left: none;
  border-radius: 0 11rpx 11rpx 0;
  margin-left: 4rpx;
  transition: border-color var(--duration-fast) ease;
}

.control-btn-active .speaker-wave { border-color: var(--accent); }

.speaker-wave-2 {
  width: 10rpx;
  height: 30rpx;
  border: 2rpx solid var(--accent);
  border-left: none;
  border-radius: 0 15rpx 15rpx 0;
  margin-left: 2rpx;
  opacity: 0.4;
  animation: fadeIn 0.3s ease-out;
}

.icon-phone-down {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-receiver {
  width: 32rpx;
  height: 8rpx;
  background: #ffffff;
  border-radius: 4rpx;
  transform: rotate(135deg);
}

.phone-arrow {
  position: absolute;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid #ffffff;
  bottom: 6rpx;
}

/* ═══════════════════════════════════════
   Landing View Styles
   ═══════════════════════════════════════ */

.landing-view .landing-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 160rpx 48rpx 80rpx;
  position: relative;
  z-index: 1;
}

.landing-view .brand-mark {
  margin-bottom: 48rpx;
}

.landing-view .avatar-zone {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.landing-view .avatar-ring-outer {
  position: absolute;
  inset: -16rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.12);
  animation: ringPulse 3s ease-in-out infinite;
}

.landing-view .avatar-ring-mid {
  position: absolute;
  inset: -8rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(196, 113, 90, 0.06);
  animation: ringPulse 3s ease-in-out infinite 0.5s;
}

.landing-view .avatar-frame {
  width: 100%;
  height: 100%;
  border-radius: 9999rpx;
  overflow: hidden;
  position: relative;
  border: 2rpx solid var(--border-medium);
}

.landing-view .ai-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: contrast(1.05) saturate(0.9);
}

.landing-view .title-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 80rpx;
}

.landing-view .brand-title {
  position: relative;
  display: flex;
  align-items: baseline;
  line-height: 1;
  z-index: 1;
}

.landing-view .brand-title::before {
  content: 'AiTalk';
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  font-size: 96rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
  color: var(--accent);
  opacity: 0.10;
  z-index: -1;
  white-space: nowrap;
}

.landing-view .brand-title::after {
  content: '';
  position: absolute;
  bottom: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, var(--accent-warm), transparent);
  opacity: 0.5;
}

.landing-view .title-part {
  font-size: 96rpx;
  letter-spacing: 0.02em;
  line-height: 1;
}

.landing-view .title-ai {
  font-weight: 700;
  color: var(--text-primary);
}

.landing-view .title-talk {
  font-weight: 300;
  color: var(--accent);
  margin-left: 4rpx;
}

.landing-view .brand-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 400;
  letter-spacing: 0.06em;
  margin-top: 16rpx;
}

.landing-view .action-area {
  width: 100%;
  display: flex;
  justify-content: center;
}

.landing-view .btn-start {
  width: 100%;
  max-width: 480rpx;
  background: var(--text-primary);
  color: var(--bg-base);
  border-radius: 9999rpx;
  padding: 32rpx 56rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: transform var(--duration-fast) var(--ease-spring),
              box-shadow var(--duration-normal) var(--ease-smooth);
}

.landing-view .btn-start:active {
  transform: scale(0.96);
}

.landing-view .btn-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid var(--bg-base);
  border-right: 3rpx solid var(--bg-base);
  transform: rotate(45deg);
  opacity: 0.8;
}

.landing-view .landing-footer {
  position: absolute;
  bottom: 64rpx;
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
}

.landing-view .footer-text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

/* Landing entrance animations */
.landing-view.view-active .brand-mark {
  animation: fadeInUp 0.7s var(--ease-out-expo) both 0.1s;
}

.landing-view.view-active .title-section {
  animation: fadeInUp 0.7s var(--ease-out-expo) both 0.25s;
}

.landing-view.view-active .action-area {
  animation: fadeInUp 0.7s var(--ease-out-expo) both 0.45s;
}

.landing-view.view-active .landing-footer {
  animation: fadeIn 0.6s var(--ease-smooth) both 0.7s;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══════════════════════════════════════
   Transition Animations (Landing → Call)
   ═══════════════════════════════════════ */

/* Landing exit */
.landing-view.transitioning .avatar-zone {
  animation: avatarShrink 0.55s var(--ease-out-expo) forwards !important;
}

.landing-view.transitioning .avatar-ring-outer,
.landing-view.transitioning .avatar-ring-mid {
  animation: ringExpand 0.55s var(--ease-out-expo) forwards !important;
}

.landing-view.transitioning .brand-mark,
.landing-view.transitioning .title-section,
.landing-view.transitioning .action-area,
.landing-view.transitioning .landing-footer {
  animation: contentFadeOut 0.4s var(--ease-smooth) forwards;
}

/* Call entrance */
.call-view.view-active .call-avatar-enter {
  animation: avatarFadeIn 0.5s var(--ease-out-expo) both;
}

.call-view.view-active .call-info {
  animation: fadeInUp 0.45s var(--ease-out-expo) 0.1s both;
}

.call-view.view-active .action-area {
  animation: fadeInUp 0.45s var(--ease-out-expo) 0.2s both;
}

.call-view.view-active .controls {
  animation: fadeInUp 0.45s var(--ease-out-expo) 0.25s both;
}

@keyframes avatarShrink {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(0.85); opacity: 0; }
}

@keyframes ringExpand {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(2.5); opacity: 0; }
}

@keyframes contentFadeOut {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-12rpx); }
}

@keyframes avatarFadeIn {
  0% { transform: scale(0.95); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* Keep landing elements in exit state when view is hidden
   (prevents a flash of original styles when animation class is removed) */
.landing-view.view-inactive .avatar-zone {
  transform: scale(0.85);
  opacity: 0;
}

.landing-view.view-inactive .avatar-ring-outer,
.landing-view.view-inactive .avatar-ring-mid {
  transform: scale(2.5);
  opacity: 0;
}

.landing-view.view-inactive .brand-mark,
.landing-view.view-inactive .title-section,
.landing-view.view-inactive .action-area,
.landing-view.view-inactive .landing-footer {
  opacity: 0;
  transform: translateY(-12rpx);
}

/* Keep call elements hidden until entrance animation starts
   (prevents a flash before animation-fill-mode kicks in) */
.call-view.view-inactive .call-avatar-enter,
.call-view.view-inactive .call-info,
.call-view.view-inactive .action-area,
.call-view.view-inactive .controls {
  opacity: 0;
}


/* ═══════════════════════════════════════

/* ═══════════════════════════════════════
   Form View
   ═══════════════════════════════════════ */

.form-view {
  padding: 0;
  box-sizing: border-box;
}

.form-scroll {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.form-content {
  width: 100%;
  max-width: 620rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 36rpx;
  padding: calc(80rpx + env(safe-area-inset-top)) 40rpx calc(40rpx + env(safe-area-inset-bottom));
}

/* Title */
.form-title-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.form-title-deco {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.form-deco-line {
  width: 40rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--text-muted));
  opacity: 0.4;
}

.form-deco-line:last-child {
  background: linear-gradient(90deg, var(--text-muted), transparent);
}

.form-deco-text {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.2em;
}

.form-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.02em;
  line-height: 1.2;
}

.form-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  text-align: center;
  letter-spacing: 0.02em;
}

/* Form Card */
.form-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.65);
  box-shadow: 0 4rpx 24rpx rgba(28, 25, 23, 0.03), inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

/* Form Row */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  gap: 20rpx;
}

.form-row-stack {
  flex-direction: column;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx 0;
}

.form-row-hd {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.form-row-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

/* Age icon */
.form-icon-age {
  background: linear-gradient(135deg, rgba(196, 113, 90, 0.12), rgba(212, 165, 116, 0.08));
}

.form-icon-age::before {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid var(--accent);
  border-radius: 50% 50% 0 50%;
  transform: rotate(-45deg);
  opacity: 0.7;
}

/* Gender icon */
.form-icon-gender {
  background: linear-gradient(135deg, rgba(120, 160, 200, 0.12), rgba(160, 190, 220, 0.08));
}

.form-icon-gender::before {
  content: '';
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #7ea6e0;
  border-radius: 9999rpx;
  opacity: 0.7;
}

.form-icon-gender::after {
  content: '';
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 6rpx;
  height: 6rpx;
  border-right: 2rpx solid #7ea6e0;
  border-bottom: 2rpx solid #7ea6e0;
  opacity: 0.7;
}

/* Heart icon */
.form-icon-heart {
  background: linear-gradient(135deg, rgba(220, 100, 100, 0.10), rgba(240, 140, 140, 0.06));
}

.form-icon-heart::before,
.form-icon-heart::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 13rpx;
  background: #dc7a7a;
  border-radius: 8rpx 8rpx 0 0;
  transform-origin: 0 100%;
  opacity: 0.6;
}

.form-icon-heart::before {
  left: 18rpx;
  transform: rotate(-45deg);
}

.form-icon-heart::after {
  left: 10rpx;
  transform: rotate(45deg);
  transform-origin: 100% 100%;
}

/* Briefcase icon */
.form-icon-briefcase {
  background: linear-gradient(135deg, rgba(160, 140, 100, 0.12), rgba(190, 170, 130, 0.08));
}

.form-icon-briefcase::before {
  content: '';
  width: 14rpx;
  height: 10rpx;
  border: 2rpx solid #a89868;
  border-radius: 2rpx;
  opacity: 0.7;
}

.form-icon-briefcase::after {
  content: '';
  position: absolute;
  top: 9rpx;
  width: 8rpx;
  height: 4rpx;
  border: 2rpx solid #a89868;
  border-bottom: none;
  border-radius: 2rpx 2rpx 0 0;
  opacity: 0.7;
}

/* MBTI icon */
.form-icon-mbti {
  background: linear-gradient(135deg, rgba(140, 120, 180, 0.12), rgba(170, 150, 210, 0.08));
}

.form-icon-mbti::before {
  content: '';
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #9a86c8;
  border-radius: 3rpx;
  opacity: 0.7;
}

.form-icon-mbti::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  background: #9a86c8;
  border-radius: 1rpx;
  opacity: 0.5;
}

/* Status icon */
.form-icon-status {
  background: linear-gradient(135deg, rgba(100, 160, 140, 0.12), rgba(130, 190, 170, 0.08));
}

.form-icon-status::before {
  content: '';
  width: 14rpx;
  height: 10rpx;
  border: 2rpx solid #6aaa8e;
  border-radius: 2rpx;
  opacity: 0.7;
}

.form-icon-status::after {
  content: '';
  position: absolute;
  bottom: 9rpx;
  right: 10rpx;
  width: 0;
  height: 0;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-top: 5rpx solid #6aaa8e;
  opacity: 0.7;
}

.form-row-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* Value / Picker */
.form-row-value {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 9999rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  transition: all 0.25s var(--ease-spring);
}

.form-row-value:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 2rpx 12rpx rgba(28, 25, 23, 0.06);
}

.form-row-placeholder {
  color: var(--text-muted);
}

/* Textarea */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  max-height: 200rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-primary);
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  transition: all 0.25s var(--ease-spring);
}

.form-textarea:focus {
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 2rpx 16rpx rgba(28, 25, 23, 0.05);
  border-color: rgba(196, 113, 90, 0.15);
}

.form-textarea-placeholder {
  color: var(--text-muted);
}

.form-chevron {
  width: 8rpx;
  height: 8rpx;
  border-right: 2rpx solid var(--text-muted);
  border-bottom: 2rpx solid var(--text-muted);
  transform: rotate(45deg);
  opacity: 0.4;
}

/* Divider */
.form-row-divider {
  height: 1rpx;
  margin: 0 8rpx;
  background: linear-gradient(90deg, transparent, rgba(28, 25, 23, 0.05), transparent);
}

/* Tags */
.form-row-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding-left: 54rpx;
}

.form-row-tag {
  padding: 14rpx 32rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(28, 25, 23, 0.05);
  transition: all 0.3s var(--ease-spring);
}

.form-row-tag-active {
  color: #ffffff;
  background: var(--text-primary);
  border-color: var(--text-primary);
  box-shadow: 0 4rpx 20rpx rgba(28, 25, 23, 0.12);
  transform: scale(1.04);
  animation: tagPop 0.35s var(--ease-spring);
}

.form-row-tag:active {
  transform: scale(0.94);
}

@keyframes tagPop {
  0% { transform: scale(1); }
  40% { transform: scale(1.08); }
  100% { transform: scale(1.04); }
}

/* Form Action */
.form-action {
  width: 100%;
}

/* Form view button */
.form-view .btn-start {
  width: 100%;
  max-width: 480rpx;
  background: rgba(28, 25, 23, 0.10);
  color: var(--text-muted);
  border-radius: 9999rpx;
  padding: 32rpx 56rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: all 0.45s var(--ease-spring);
}

.form-view .btn-start::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 9999rpx;
  background: radial-gradient(circle at center, rgba(255,255,255,0.35) 0%, transparent 70%);
  opacity: 0;
  transform: scale(0.5);
  transition: opacity 0.3s ease, transform 0.5s var(--ease-out-expo);
}

.form-view .btn-start:active::after {
  opacity: 1;
  transform: scale(2.2);
}

.form-view .btn-start:active {
  transform: scale(0.94);
}

.form-view .btn-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid var(--text-muted);
  border-right: 3rpx solid var(--text-muted);
  transform: rotate(45deg);
  opacity: 0.35;
  transition: all 0.45s var(--ease-spring);
}

.btn-start-ready {
  background: var(--accent) !important;
  color: #ffffff !important;
  box-shadow: 0 8rpx 32rpx rgba(196, 113, 90, 0.28);
  animation: btnPulse 2.4s ease-in-out infinite;
}

.btn-start-ready .btn-arrow {
  border-color: #ffffff !important;
  opacity: 0.9;
}

.btn-start-ready:active {
  box-shadow: 0 4rpx 16rpx rgba(196, 113, 90, 0.35) !important;
}

@keyframes btnPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 8rpx 32rpx rgba(196, 113, 90, 0.28); }
  50% { transform: scale(1.015); box-shadow: 0 10rpx 40rpx rgba(196, 113, 90, 0.32); }
}

/* Footer */
.form-footer {
  text-align: center;
}

.form-footer text {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

/* Form entrance animations */
.form-view.view-active .form-title-section {
  animation: fadeInUp 0.6s var(--ease-out-expo) both 0.05s;
}

.form-view.view-active .form-card {
  animation: fadeInUp 0.7s var(--ease-out-expo) both 0.15s;
}

.form-view.view-active .form-action {
  animation: fadeInUp 0.6s var(--ease-out-expo) both 0.32s;
}

.form-view.view-active .form-footer {
  animation: fadeIn 0.5s var(--ease-smooth) both 0.42s;
}

/* Keep form elements hidden until entrance animation starts */
.form-view.view-inactive .form-title-section,
.form-view.view-inactive .form-card,
.form-view.view-inactive .form-action,
.form-view.view-inactive .form-footer {
  opacity: 0;
}
