.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

.tab-bar-bg {
  background: rgba(250, 249, 247, 0.88);
  backdrop-filter: saturate(200%) blur(48rpx);
  -webkit-backdrop-filter: saturate(200%) blur(48rpx);
  border-top: 1rpx solid rgba(28, 25, 23, 0.04);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 18rpx 20rpx 22rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 28rpx;
  position: relative;
  gap: 8rpx;
  transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item:active {
  transform: scale(0.88);
}

.tab-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
}

.tab-icon {
  position: relative;
  transition: all 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

/* Match icon */
.icon-match::before {
  content: '';
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
  transform: translate(-50%, -50%) rotate(45deg);
  top: 50%;
  left: 50%;
}

/* Memory icon */
.icon-memory::before {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -30%);
}
.icon-memory::after {
  content: '';
  position: absolute;
  width: 24rpx;
  height: 16rpx;
  border: 2rpx solid currentColor;
  border-radius: 2rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -80%);
}

/* Profile icon */
.icon-profile::before {
  content: '';
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 9999rpx;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.icon-profile::after {
  content: '';
  position: absolute;
  width: 26rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 12rpx 12rpx 0 0;
  border-bottom: none;
  top: 70%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.tab-label {
  font-size: 20rpx;
  font-weight: 400;
  color: rgba(28, 25, 23, 0.45);
  letter-spacing: 0.04em;
  transition: all 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

.tab-icon {
  color: rgba(28, 25, 23, 0.45);
}

.tab-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(196, 113, 90, 0.4), transparent);
  opacity: 0;
  filter: blur(20rpx);
  transform: translate(-50%, -60%);
  transition: opacity 400ms ease;
  pointer-events: none;
}

/* Active State */
.tab-item.active .tab-label {
  color: #1c1917;
  font-weight: 500;
}

.tab-item.active .tab-icon {
  color: #c4715a;
  animation: tabBounce 450ms cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item.active .tab-glow {
  opacity: 0.2;
}

@keyframes tabBounce {
  0% { transform: scale(1); }
  30% { transform: scale(1.3); }
  55% { transform: scale(0.88); }
  75% { transform: scale(1.05); }
  100% { transform: scale(1); }
}
