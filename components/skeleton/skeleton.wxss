.skeleton-wrap {
  padding: 24rpx 32rpx;
}

.skeleton-wrap.shimmer .skeleton-circle,
.skeleton-wrap.shimmer .skeleton-line {
  background: linear-gradient(90deg, #f0eeeb 25%, #faf8f5 50%, #f0eeeb 75%);
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.6s ease infinite;
}

@keyframes skeleton-shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

/* row (list variant) */
.skeleton-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  opacity: 0;
  animation: skeleton-fadeIn 0.3s ease forwards;
}

@keyframes skeleton-fadeIn {
  to { opacity: 1; }
}

.skeleton-lines {
  flex: 1;
  margin-left: 24rpx;
}

/* circles */
.skeleton-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.skeleton-circle--small {
  width: 56rpx;
  height: 56rpx;
}

.skeleton-circle--large {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto 24rpx;
}

/* lines */
.skeleton-line {
  height: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.skeleton-line--short {
  width: 40%;
}

.skeleton-line--medium {
  width: 65%;
}

.skeleton-line--long {
  width: 90%;
}

.skeleton-line--title {
  width: 50%;
  height: 28rpx;
  margin-bottom: 20rpx;
}

.skeleton-line--center {
  margin-left: auto;
  margin-right: auto;
}

.skeleton-line--bubble {
  flex: 1;
  height: 64rpx;
  border-radius: 24rpx;
  margin: 0 16rpx;
}

/* card variant */
.skeleton-card {
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  background: var(--bg-elevated, #fff);
  opacity: 0;
  animation: skeleton-fadeIn 0.3s ease forwards;
}

/* chat bubble variant */
.skeleton-bubble {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  opacity: 0;
  animation: skeleton-fadeIn 0.3s ease forwards;
}

.skeleton-bubble--left {
  justify-content: flex-start;
  padding-right: 120rpx;
}

.skeleton-bubble--right {
  justify-content: flex-end;
  padding-left: 120rpx;
}

/* profile variant */
.skeleton-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  opacity: 0;
  animation: skeleton-fadeIn 0.3s ease forwards;
}
