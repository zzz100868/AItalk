.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: rgba(250, 249, 247, 0.7);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
  animation: fadeIn 0.25s ease both;
}

.modal-dialog {
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 32rpx;
  width: 100%;
  max-width: 600rpx;
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  box-shadow: 0 24rpx 80rpx rgba(196, 113, 90, 0.1), 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: modalSlideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
}

@keyframes modalSlideUp {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-header {
  font-size: 32rpx;
  font-weight: 400;
  color: #1c1917;
  text-align: center;
  letter-spacing: 0;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.modal-input {
  background: rgba(28, 25, 23, 0.04);
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1c1917;
  box-sizing: border-box;
  width: 100%;
  height: 80rpx;
}

.modal-textarea {
  background: rgba(28, 25, 23, 0.04);
  border: 1rpx solid rgba(28, 25, 23, 0.06);
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1c1917;
  height: 240rpx;
  line-height: 1.7;
  box-sizing: border-box;
  width: 100%;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.modal-btn {
  padding: 16rpx 36rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: all 0.2s ease;
  letter-spacing: 0;
}

.modal-btn.cancel {
  color: #57534e;
  background: rgba(28, 25, 23, 0.04);
}

.modal-btn.confirm {
  color: #fff;
  background: linear-gradient(135deg, #c4715a, #d4a574);
  box-shadow: 0 4rpx 16rpx rgba(196, 113, 90, 0.25);
}

.modal-btn:active {
  transform: scale(0.96);
}
