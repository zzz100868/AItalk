/* ══════════════════════════════════════
   Shared Styles — @import in page WXSS
   ══════════════════════════════════════ */

/* ── Back Arrow ── */
.back-arrow {
  width: 24rpx;
  height: 24rpx;
  border-left: 3rpx solid var(--text-primary);
  border-bottom: 3rpx solid var(--text-primary);
  transform: rotate(45deg);
}

/* ── Heart Icon ── */
.icon-heart {
  position: relative;
  width: 24rpx;
  height: 20rpx;
}

.icon-heart::before,
.icon-heart::after {
  content: '';
  position: absolute;
  width: 13rpx;
  height: 20rpx;
  background: var(--text-muted);
  border-radius: 12rpx 12rpx 0 0;
  transform-origin: 0 100%;
  transition: background var(--duration-fast) ease;
}

.icon-heart::before {
  left: 13rpx;
  transform: rotate(-45deg);
}

.icon-heart::after {
  left: 0;
  transform: rotate(45deg);
  transform-origin: 100% 100%;
}

.heart-active::before,
.heart-active::after {
  background: var(--accent);
}

.heart-beating {
  animation: heart-beat 0.5s var(--ease-spring);
}

@keyframes heart-beat {
  0% { transform: scale(1); }
  20% { transform: scale(1.4); }
  40% { transform: scale(1.1); }
  60% { transform: scale(1.3); }
  80% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

.action-liked .action-count {
  color: var(--accent);
  font-weight: 600;
}

/* ── Comment Icon ── */
.icon-comment::before {
  content: '';
  width: 26rpx;
  height: 24rpx;
  border: 2rpx solid var(--text-muted);
  border-radius: 8rpx 8rpx 8rpx 0;
  position: absolute;
}

.icon-comment::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 2rpx;
  width: 6rpx;
  height: 6rpx;
  border-bottom: 2rpx solid var(--text-muted);
  border-left: 2rpx solid var(--text-muted);
  transform: rotate(-45deg);
}

/* ── Action Icon Container ── */
.action-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-count {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
  transition: color var(--duration-fast) ease, transform var(--duration-fast) var(--ease-spring);
}

/* ── Comments Section ── */
.comments-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 0;
  overflow: hidden;
  transform-origin: top;
  max-height: 0;
  opacity: 0;
  transform: translateY(-12rpx);
  transition: max-height 0.4s var(--ease-out-expo),
              opacity 0.3s var(--ease-smooth),
              transform 0.4s var(--ease-out-expo),
              margin-top 0.3s ease;
}

.comments-section.is-expanded {
  max-height: 2000rpx;
  opacity: 1;
  transform: translateY(0);
  margin-top: 8rpx;
}

.comments-divider {
  height: 1rpx;
  background: linear-gradient(90deg, var(--border-subtle) 0%, transparent 100%);
  margin: 4rpx 0;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  animation: fadeInUp 0.3s var(--ease-out-expo) both;
}

.comment-item:nth-child(1) { animation-delay: 0.05s; }
.comment-item:nth-child(2) { animation-delay: 0.1s; }
.comment-item:nth-child(3) { animation-delay: 0.15s; }
.comment-item:nth-child(4) { animation-delay: 0.2s; }
.comment-item:nth-child(5) { animation-delay: 0.25s; }

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
}

.comment-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.comment-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-author {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.comment-reply-btn {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 4rpx 12rpx;
  transition: color var(--duration-fast) ease;
}

.comment-reply-btn:active {
  color: var(--accent);
}

.comment-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding: 4rpx 0;
  border-radius: 8rpx;
  transition: background 0.15s ease;
}

.comment-text:active {
  background: var(--bg-surface);
}

/* ── Replies ── */
.replies-wrap {
  display: flex;
  flex-direction: column;
  margin-top: 8rpx;
  padding: 4rpx 12rpx;
  background: var(--bg-base);
  border-radius: 12rpx;
  border: 1rpx solid var(--border-subtle);
}

.reply-item {
  display: flex;
  gap: 10rpx;
  align-items: flex-start;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}

.reply-item-last {
  border-bottom: none;
}

.reply-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 9999rpx;
  object-fit: cover;
  border: 1rpx solid var(--border-subtle);
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reply-content {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
}

.reply-meta {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.reply-author {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.reply-target {
  font-size: 22rpx;
  color: var(--text-muted);
}

.reply-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  padding: 4rpx 0;
  border-radius: 8rpx;
  transition: background 0.15s ease;
}

.reply-text:active {
  background: var(--bg-surface);
}

/* ── Reply Hint ── */
.reply-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  background: var(--accent-dim);
  border-radius: 9999rpx;
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 500;
}

.reply-hint-close {
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-x {
  width: 16rpx;
  height: 16rpx;
  position: relative;
}

.close-x::before,
.close-x::after {
  content: '';
  position: absolute;
  width: 2rpx;
  height: 16rpx;
  background: var(--accent);
  border-radius: 1rpx;
  left: 50%;
  top: 0;
}

.close-x::before {
  transform: rotate(45deg);
}

.close-x::after {
  transform: rotate(-45deg);
}

/* ── Comment Input ── */
.comment-input-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-top: 8rpx;
}

.comment-input {
  flex: 1;
  background: var(--bg-surface);
  border: 1rpx solid var(--border-subtle);
  border-radius: 9999rpx;
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  transition: border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease;
}

.comment-input:focus {
  border-color: var(--border-medium);
}

.comment-placeholder {
  color: var(--text-muted);
}

/* ── Skeleton Screen ── */
.skeleton-wrap {
  padding: 24rpx 32rpx;
}

.skeleton-card {
  background: var(--surface);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--border-subtle);
}

.skeleton-header-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.skeleton-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--border-subtle);
  margin-right: 16rpx;
  animation: skeleton-shimmer 1.4s ease infinite;
}

.skeleton-header-text {
  flex: 1;
}

.skeleton-line {
  height: 20rpx;
  background: var(--border-subtle);
  border-radius: 6rpx;
  margin-bottom: 12rpx;
  animation: skeleton-shimmer 1.4s ease infinite;
}

.skeleton-line-short { width: 40%; }
.skeleton-line-shorter { width: 25%; }
.skeleton-line-medium { width: 70%; }

.skeleton-line-tiny {
  width: 80rpx;
  height: 16rpx;
}

.skeleton-image {
  width: 100%;
  height: 300rpx;
  background: var(--border-subtle);
  border-radius: 12rpx;
  margin: 16rpx 0;
  animation: skeleton-shimmer 1.4s ease infinite;
}

.skeleton-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 8rpx;
}

@keyframes skeleton-shimmer {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}

/* ── Error State ── */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--border-subtle);
  margin-bottom: 32rpx;
  position: relative;
}

.error-icon::before,
.error-icon::after {
  content: '';
  position: absolute;
  background: var(--text-muted);
  border-radius: 2rpx;
}

.error-icon::before {
  width: 8rpx;
  height: 40rpx;
  top: 30rpx;
  left: 50%;
  transform: translateX(-50%);
}

.error-icon::after {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.error-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 40rpx;
}

.error-retry {
  padding: 18rpx 56rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--accent);
}

.error-retry:active {
  opacity: 0.85;
  transform: scale(0.96);
}

/* ── Load More ── */
.load-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 80rpx;
  gap: 16rpx;
}

.load-more-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid var(--border-subtle);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spinner-rotate 0.8s linear infinite;
}

@keyframes spinner-rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.load-more-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.no-more-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 80rpx;
  gap: 20rpx;
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: var(--border-subtle);
  max-width: 120rpx;
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* ── Animations ── */
@keyframes fadeInUp {
  from { transform: translateY(20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
