{
  "pages": [
    "pages/index/index",
    "pages/match/match",
    "pages/memory/memory",
    "pages/profile/profile"
  ],
  "subPackages": [
    {
      "root": "pkg-settings",
      "name": "settings-pkg",
      "pages": [
        "settings/settings",
        "editProfile/editProfile",
        "accountSecurity/accountSecurity"
      ]
    },
    {
      "root": "pkg-social",
      "name": "social-pkg",
      "pages": [
        "userHome/userHome",
        "notifications/notifications"
      ]
    }
  ],
  "preloadRule": {
    "pages/profile/profile": {
      "network": "all",
      "packages": ["settings-pkg"]
    },
    "pages/match/match": {
      "network": "wifi",
      "packages": ["social-pkg"]
    }
  },
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#faf9f7",
    "navigationBarTitleText": "赛博聊机",
    "navigationBarTextStyle": "black",
    "navigationStyle": "custom",
    "backgroundColor": "#faf9f7"
  },
  "usingComponents": {
    "page-header": "/components/page-header/page-header",
    "edit-modal": "/components/edit-modal/edit-modal",
    "skeleton": "/components/skeleton/skeleton"
  },
  "tabBar": {
    "custom": true,
    "color": "#d1d5db",
    "selectedColor": "#f4a3ad",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/match/match",
        "text": "匹配",
        "iconPath": "images/tab_match.png",
        "selectedIconPath": "images/tab_match_active.png"
      },
      {
        "pagePath": "pages/memory/memory",
        "text": "记忆库",
        "iconPath": "images/tab_memory.png",
        "selectedIconPath": "images/tab_memory_active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "images/tab_profile.png",
        "selectedIconPath": "images/tab_profile_active.png"
      }
    ]
  },
  "sitemapLocation": "sitemap.json"
}
